{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pm-plugin.local/schemas/dev-session-v2.json",
  "title": "PM dev session v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "slug",
    "status",
    "phase",
    "phase_attempt",
    "created_at",
    "updated_at",
    "source",
    "task",
    "execution",
    "authority",
    "authority_log",
    "routing",
    "evidence",
    "attempts",
    "blockers",
    "history"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "run_id": { "type": "string", "pattern": "^dev_" },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "status": { "enum": ["active", "blocked", "handoff", "complete"] },
    "phase": { "$ref": "#/$defs/phase" },
    "phase_attempt": { "type": "integer", "minimum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/source" },
    "task": { "$ref": "#/$defs/task" },
    "execution": { "$ref": "#/$defs/execution" },
    "authority": { "$ref": "#/$defs/authority" },
    "authority_log": {
      "type": "array",
      "items": { "$ref": "#/$defs/authority_grant" }
    },
    "routing": { "$ref": "#/$defs/routing" },
    "evidence": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/evidence_set" }
    },
    "attempts": {
      "type": "array",
      "items": { "$ref": "#/$defs/attempt_record" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocker_record" }
    },
    "history": {
      "type": "array",
      "items": { "$ref": "#/$defs/history_record" }
    },
    "migration": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["legacy_path", "migrated_at"],
          "properties": {
            "legacy_path": { "type": "string", "pattern": "^/" },
            "migrated_at": { "type": "string", "format": "date-time" }
          }
        }
      ]
    }
  },
  "$defs": {
    "phase": {
      "enum": [
        "intake",
        "workspace",
        "readiness",
        "implementation",
        "design-critique",
        "qa",
        "review",
        "ship",
        "retro"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_root", "worktree", "branch", "default_branch", "base_commit"],
      "properties": {
        "repo_root": { "type": "string", "pattern": "^/" },
        "worktree": { "type": "string", "pattern": "^/" },
        "branch": { "type": "string", "minLength": 1 },
        "default_branch": { "type": "string", "minLength": 1 },
        "base_commit": { "type": "string", "minLength": 1 },
        "delivery_remote": { "type": "string", "minLength": 1 }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "behavioral",
        "security",
        "auth",
        "data",
        "destructive_data",
        "external_contract",
        "operational",
        "ui",
        "reversibility",
        "cross_module"
      ],
      "properties": {
        "behavioral": { "type": "integer", "minimum": 0, "maximum": 3 },
        "security": { "type": "integer", "minimum": 0, "maximum": 3 },
        "auth": { "type": "integer", "minimum": 0, "maximum": 3 },
        "data": { "type": "integer", "minimum": 0, "maximum": 3 },
        "destructive_data": { "type": "boolean" },
        "external_contract": { "type": "integer", "minimum": 0, "maximum": 3 },
        "operational": { "type": "integer", "minimum": 0, "maximum": 3 },
        "ui": { "type": "integer", "minimum": 0, "maximum": 3 },
        "reversibility": { "type": "integer", "minimum": 0, "maximum": 3 },
        "cross_module": { "type": "integer", "minimum": 0, "maximum": 3 }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference",
        "kind",
        "size",
        "risk",
        "risk_tier",
        "acceptance_criteria",
        "work_units"
      ],
      "properties": {
        "reference": { "type": ["string", "null"] },
        "rfc_sidecar": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256", "schema_version", "slug"],
              "properties": {
                "path": { "type": "string", "pattern": "^/" },
                "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
                "schema_version": { "const": 3 },
                "slug": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "kind": { "type": "string", "minLength": 1 },
        "size": { "enum": ["XS", "S", "M", "L", "XL", "unknown"] },
        "risk": { "$ref": "#/$defs/risk" },
        "risk_tier": { "type": "string", "minLength": 1 },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "work_units": { "type": "array", "items": { "$ref": "#/$defs/work_unit" } }
      }
    },
    "work_unit_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "reason", "commit", "recorded_at"],
      "properties": {
        "from": { "enum": ["pending", "running", "completed", "blocked", "failed"] },
        "to": { "enum": ["pending", "running", "completed", "blocked", "failed"] },
        "reason": { "type": "string", "minLength": 1 },
        "commit": { "type": ["string", "null"] },
        "recorded_at": { "type": "string", "format": "date-time" }
      }
    },
    "work_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "depends_on", "owns", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "owns": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "contract": { "$ref": "#/$defs/work_unit_contract" },
        "status": { "enum": ["pending", "running", "completed", "blocked", "failed"] },
        "base_commit": { "type": "string", "minLength": 1 },
        "assigned_worktree": { "type": "string", "pattern": "^/" },
        "assigned_branch": { "type": "string", "minLength": 1 },
        "result": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/work_unit_result" }]
        },
        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/work_unit_transition" }
        },
        "updated_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": { "enum": ["running", "completed", "blocked", "failed"] }
            }
          },
          "then": {
            "required": ["base_commit", "assigned_worktree", "assigned_branch"]
          }
        },
        {
          "if": {
            "properties": { "status": { "enum": ["completed", "blocked", "failed"] } }
          },
          "then": { "required": ["result"] }
        },
        {
          "if": { "properties": { "status": { "enum": ["pending", "running"] } } },
          "then": { "properties": { "result": { "type": "null" } } }
        },
        {
          "if": { "properties": { "status": { "const": "completed" } } },
          "then": {
            "properties": {
              "result": {
                "allOf": [
                  { "$ref": "#/$defs/work_unit_result" },
                  {
                    "type": "object",
                    "properties": { "status": { "const": "completed" } }
                  }
                ]
              }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "blocked" } } },
          "then": {
            "properties": {
              "result": {
                "allOf": [
                  { "$ref": "#/$defs/work_unit_result" },
                  {
                    "type": "object",
                    "properties": { "status": { "const": "blocked" } }
                  }
                ]
              }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "failed" } } },
          "then": {
            "properties": {
              "result": {
                "allOf": [
                  { "$ref": "#/$defs/work_unit_result" },
                  {
                    "type": "object",
                    "properties": { "status": { "const": "failed" } }
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "work_unit_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptance_criteria",
        "approach",
        "verification_commands",
        "test_hooks"
      ],
      "properties": {
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "approach": { "type": "string", "minLength": 1 },
        "verification_commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "test_hooks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "work_unit_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "work_unit_id",
        "status",
        "summary",
        "commit",
        "files_changed",
        "evidence",
        "blocker",
        "runtime"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "work_unit_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["completed", "blocked", "failed"] },
        "summary": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "commit": { "type": ["string", "null"], "minLength": 1 },
        "files_changed": { "type": "integer", "minimum": 0 },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "exit_code"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "exit_code": { "type": "integer" }
            },
            "additionalProperties": true
          }
        },
        "blocker": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["reason"],
              "properties": { "reason": { "type": "string", "minLength": 1 } },
              "additionalProperties": true
            }
          ]
        },
        "runtime": {
          "type": "object",
          "required": ["provider"],
          "properties": { "provider": { "type": "string", "minLength": 1 } },
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "completed" } } },
          "then": {
            "properties": {
              "commit": { "type": "string", "minLength": 1 },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "contains": {
                  "type": "object",
                  "required": ["exit_code"],
                  "properties": { "exit_code": { "const": 0 } }
                }
              },
              "blocker": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "status": { "enum": ["blocked", "failed"] } } },
          "then": {
            "required": ["reason"],
            "properties": { "blocker": { "type": "object" } }
          }
        }
      ]
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "runtime",
        "model",
        "reasoning",
        "mode",
        "runtime_session_id"
      ],
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "reasoning": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["inline", "delegated", "headless"] },
        "runtime_session_id": { "type": ["string", "null"] }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_writes",
        "commit",
        "push_feature_branch",
        "create_pr",
        "merge",
        "tracker_updates"
      ],
      "properties": {
        "local_writes": { "type": "boolean" },
        "commit": { "type": "boolean" },
        "push_feature_branch": { "type": "boolean" },
        "create_pr": { "type": "boolean" },
        "merge": { "type": "boolean" },
        "tracker_updates": { "type": "boolean" }
      }
    },
    "authority_grant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actions", "reason", "granted_at"],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["push_feature_branch", "create_pr", "merge", "tracker_updates"]
          }
        },
        "reason": { "type": "string", "minLength": 1 },
        "granted_at": { "type": "string", "format": "date-time" }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_phases",
        "required_gates",
        "review_mode",
        "decision_version",
        "reasons"
      ],
      "properties": {
        "required_phases": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/phase" }
        },
        "required_gates": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "review_mode": { "enum": ["code-scan", "full"] },
        "decision_version": { "type": "integer", "minimum": 1 },
        "decision_log": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["version", "reason", "recorded_at"],
            "properties": {
              "version": { "type": "integer", "minimum": 2 },
              "reason": { "type": "string", "minLength": 1 },
              "recorded_at": { "type": "string", "format": "date-time" }
            }
          }
        },
        "reasons": { "type": "array", "items": { "type": "string" } }
      },
      "allOf": [
        {
          "if": {
            "properties": { "decision_version": { "type": "integer", "minimum": 2 } }
          },
          "then": {
            "required": ["decision_log"],
            "properties": { "decision_log": { "type": "array", "minItems": 1 } }
          }
        }
      ]
    },
    "evidence_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "command", "exit_code", "artifact"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "command": { "type": ["string", "null"] },
        "exit_code": { "type": "integer" },
        "artifact": { "type": ["string", "null"] }
      }
    },
    "evidence_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "records", "recorded_at"],
      "properties": {
        "commit": { "type": ["string", "null"] },
        "records": { "type": "array", "items": { "$ref": "#/$defs/evidence_record" } },
        "recorded_at": { "type": "string", "format": "date-time" },
        "verified_commit": { "type": "string", "minLength": 1 },
        "verified_at": { "type": "string", "format": "date-time" },
        "verification_records": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence_record" }
        }
      },
      "dependentRequired": {
        "verified_commit": ["verified_at", "verification_records"],
        "verified_at": ["verified_commit", "verification_records"],
        "verification_records": ["verified_commit", "verified_at"]
      }
    },
    "runtime_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "reasoning"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "reasoning": { "type": "string", "minLength": 1 },
        "session_id": { "type": ["string", "null"] }
      }
    },
    "attempt_record": {
      "type": "object",
      "required": ["phase", "attempt", "status", "summary", "commit", "recorded_at", "runtime"],
      "properties": {
        "phase": { "$ref": "#/$defs/phase" },
        "attempt": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["passed", "failed", "blocked", "noop"] },
        "summary": { "type": "string", "minLength": 1 },
        "commit": { "type": ["string", "null"] },
        "recorded_at": { "type": "string", "format": "date-time" },
        "runtime": { "$ref": "#/$defs/runtime_result" }
      }
    },
    "blocker_record": {
      "type": "object",
      "required": ["code", "reason", "phase", "recorded_at"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "remediation": { "type": "string" },
        "phase": { "$ref": "#/$defs/phase" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "resolved_at": { "type": "string", "format": "date-time" },
        "resolution": { "type": "string", "minLength": 1 }
      },
      "dependentRequired": {
        "resolved_at": ["resolution"],
        "resolution": ["resolved_at"]
      }
    },
    "history_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prior_phase",
        "next_phase",
        "reason",
        "result_hash",
        "timestamp",
        "runner_version"
      ],
      "properties": {
        "prior_phase": { "$ref": "#/$defs/phase" },
        "next_phase": { "$ref": "#/$defs/phase" },
        "reason": { "type": "string", "minLength": 1 },
        "result_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "timestamp": { "type": "string", "format": "date-time" },
        "runner_version": { "type": "string", "minLength": 1 }
      }
    },
    "phase_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "run_id",
        "phase",
        "attempt",
        "status",
        "summary",
        "commit",
        "files_changed",
        "evidence",
        "blocker",
        "runtime"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "phase": { "$ref": "#/$defs/phase" },
        "attempt": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["passed", "failed", "blocked", "noop"] },
        "summary": { "type": "string", "minLength": 1 },
        "commit": { "type": ["string", "null"] },
        "files_changed": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence_record" } },
        "blocker": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["code", "reason"],
              "properties": {
                "code": { "type": "string", "minLength": 1 },
                "reason": { "type": "string", "minLength": 1 },
                "remediation": { "type": "string" }
              }
            }
          ]
        },
        "runtime": { "$ref": "#/$defs/runtime_result" }
      }
    }
  }
}
