#!/usr/bin/env bash
# SessionStart hook — detects recently merged PRs whose Linear issues are still open.
# Outputs advisory context so the agent can reconcile on startup.
#
# Runs async to avoid blocking session start. Lightweight: one gh call + file scan.

set -euo pipefail

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-.}"
# Absolute plugin root, resolved before any cd so it survives the chdir below.
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

# Only run if the project has Linear integration
CONFIG="$PROJECT_DIR/.pm/config.json"
[ -f "$CONFIG" ] || exit 0
grep -q '"linear"' "$CONFIG" 2>/dev/null || exit 0

# Check for gh CLI
command -v gh >/dev/null 2>&1 || exit 0

cd "$PROJECT_DIR"

# Gate: did anything merge in the last 48h at all? Only mergedAt is needed —
# this is just a cheap "worth scanning sessions?" check. The authoritative
# per-branch state comes from pr-state.js below (fresh, with retry).
MERGED_PRS=$(gh pr list --state merged --limit 20 \
  --json mergedAt \
  --jq '[.[] | select(.mergedAt > (now - 172800 | todate))] | .[]' 2>/dev/null) || exit 0

[ -z "$MERGED_PRS" ] && exit 0

# Extract issue IDs from merged PR titles/branches and check for stale dev sessions
STALE_ISSUES=""

# Scan dev sessions for merged branches that weren't cleaned up
SESSION_DIR="$PROJECT_DIR/.pm/dev-sessions"
if [ -d "$SESSION_DIR" ]; then
  while IFS= read -r session; do
    if [[ "$session" == */session.json ]]; then
      ISSUE_ID=$(node -e 'const s=require(process.argv[1]); const v=String(s.task?.reference||"").match(/[A-Z]+-[0-9]+/); process.stdout.write(v?.[0]||"")' "$session" 2>/dev/null || true)
      BRANCH=$(node -e 'const s=require(process.argv[1]); process.stdout.write(String(s.source?.branch||""))' "$session" 2>/dev/null || true)
    else
      ISSUE_ID=$(grep -m1 -oE '[A-Z]+-[0-9]+' "$session" 2>/dev/null | head -1)
      BRANCH=$(grep -m1 -i '[*-]*[[:space:]]*branch:' "$session" 2>/dev/null \
        | sed 's/.*[Bb]ranch:[[:space:]]*\*\{0,2\}//' | sed 's/\*//g' | tr -d ' ' | head -1)
    fi
    [ -z "$ISSUE_ID" ] && continue
    [ -z "$BRANCH" ] && continue

    # Check if this branch's PR was merged. pr-state.js wraps the same
    # `gh pr view <branch> --json state` query with retry on transient 5xx /
    # gateway / timeout failures, so a flaky API call no longer silently drops
    # a merged PR from reconciliation. UNKNOWN (persistent failure) is treated
    # as not-merged — fail safe.
    PR_STATE=$(node "$PLUGIN_ROOT/scripts/pr-state.js" --branch "$BRANCH" 2>/dev/null) || continue
    if [ "$PR_STATE" = "MERGED" ]; then
      STALE_ISSUES="${STALE_ISSUES}  - ${ISSUE_ID} (branch: ${BRANCH}, session: $(basename "$session"))\n"
    fi
  done < <(find "$SESSION_DIR" -type f \( -name '*.md' -o -name 'session.json' \) -print)
fi

if [ -n "$STALE_ISSUES" ]; then
  printf "Post-merge reconciliation needed:\n"
  printf "These issues have merged PRs but dev sessions are still open (Linear status likely not updated):\n"
  printf "%b" "$STALE_ISSUES"
  printf "Action: For each, update Linear issue to Done and clean up the dev session file.\n"
fi
