#!/usr/bin/env bash
# SessionStart hook — pulls latest pm/ files from remote.
# Supports git and server backends. Always exits 0 — pull failure must never block the session.

set -euo pipefail

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-.}"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

# Read sync preferences and backend
SYNC_INFO=$(node -e "
  try {
    const c = JSON.parse(require('fs').readFileSync('$PROJECT_DIR/.pm/config.json','utf8'));
    const s = c.sync || {};
    const backend = s.backend || 'none';
    const enabled = s.enabled !== undefined ? s.enabled : (backend !== 'none');
    const autoPull = s.auto_pull !== undefined ? s.auto_pull : true;
    if (!enabled || !autoPull) process.stdout.write('skip');
    else process.stdout.write(backend);
  } catch { process.stdout.write('skip'); }
" 2>/dev/null || true)

[ "$SYNC_INFO" = "skip" ] || [ "$SYNC_INFO" = "none" ] && exit 0

# Pull based on backend
if [ "$SYNC_INFO" = "git" ]; then
  node "$PLUGIN_ROOT/scripts/kb-sync-git.js" pull 2>/dev/null || true
else
  node "$PLUGIN_ROOT/scripts/kb-sync.js" pull 2>/dev/null || true
fi

exit 0
