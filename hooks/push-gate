#!/usr/bin/env node
"use strict";

// PreToolUse hook (Bash matcher, async:false) — the RUNTIME ENFORCEMENT GATE for
// the PM dev push gate. It fires before EVERY Bash tool call, including loop
// workers running `claude -p`.
//
// Why this is the gate, not a git hook: PM deliberately does NOT install a git
// pre-push hook into user repos. So in a user repo this PreToolUse hook is the
// ONLY thing standing between a `git push` and the remote — there is no
// downstream backstop. (In PM's own repo it also sits in front of
// .githooks/pre-push, but it must never rely on that existing.)
//
// Threat model: a COOPERATING agent (e.g. a loop worker) that reflexively runs
// `git push` and would skip the gate by accident. It is NOT a sandbox against a
// determined agent actively evading its OWN gate.
//   FAIL-CLOSED on uncertainty: once a push to the session branch is detected
//   and a gate manifest exists, if the checker cannot be run to a clean verdict
//   we BLOCK — a checker you couldn't run is not evidence the gate passed.
//   FAIL-OPEN only for genuinely out-of-scope cases: not a push, not the session
//   branch (tag/delete/cross-branch), no manifest, or a non-PM repo.
//
// ceiling (documented, NOT chased): deliberately-obfuscated evasions —
// `eval "git push"`, an `alias git=...` indirection, base64'd commands — are out
// of scope. Defeating them requires an agent actively evading its own gate, which
// is outside the cooperating-worker threat model. Hardening the parser against
// natural agent-emitted forms (below) is where the value is; chasing obfuscation
// is not. If hard enforcement against a determined agent is ever required, the
// answer is to also install the git pre-push hook in user repos — a separate call.

const fs = require("node:fs");
const path = require("node:path");
const { spawnSync } = require("node:child_process");

const PM_PLUGIN_ROOT =
  process.env.PM_PLUGIN_ROOT || process.env.CLAUDE_PLUGIN_ROOT || path.resolve(__dirname, "..");
const HOOK_ROOT = path.resolve(__dirname, "..");

const CHECKER = path.join(PM_PLUGIN_ROOT, "scripts", "dev-gate-check.js");
const { readProjectInput } = require(
  path.join(HOOK_ROOT, "scripts", "lib", "safe-project-output.js")
);
const { validateSession } = require(
  path.join(HOOK_ROOT, "scripts", "lib", "dev-session-schema.js")
);

// The 1MB spawnSync default ENOBUFS'd on a large (e.g. 200k-row) manifest, which
// under fail-open silently allowed the push. Give the checker plenty of room; if
// it still overflows, fail-closed catches it (result.error is set → block).
const MAX_BUFFER = 64 * 1024 * 1024;
const MAX_SESSION_BYTES = 4 * 1024 * 1024;
const MAX_SESSION_DIRECTORIES = 512;

// allow / emit never call process.exit(): a bare `process.exit(0)` after a stdout
// write can truncate a large deny JSON on a pipe (Node exits before the async
// write drains). We set exitCode 0 and return; the process exits cleanly once the
// event loop drains stdout. Callers use `return allow()` / `return emitDeny()`.
function allow() {
  process.exitCode = 0;
}

function emitDeny(reason) {
  process.exitCode = 0;
  process.stdout.write(
    JSON.stringify({
      hookSpecificOutput: {
        hookEventName: "PreToolUse",
        permissionDecision: "deny",
        permissionDecisionReason: reason,
      },
    })
  );
}

// Gate ran and reported a failing/stale verdict.
function blockFailingGate(branch, manifestRel, checkerOutput) {
  emitDeny(
    [
      `PM dev gate blocked this push. Branch "${branch}" has an incomplete or stale quality gate:`,
      "",
      checkerOutput.trim(),
      "",
      `Run the missing/failing gates, refresh ${manifestRel} for the exact pushed commit, then retry the push.`,
    ].join("\n")
  );
}

// Fail-closed: a push to the session branch was detected and a gate manifest
// exists, but the checker could not be run to a clean verdict.
function blockUnverified(branch, manifestRel, detail) {
  emitDeny(
    [
      `PM dev gate could not verify this push for branch "${branch}".`,
      "",
      `The gate checker for ${manifestRel} did not produce a clean verdict${
        detail ? ` (${detail})` : ""
      }.`,
      "",
      `The gate cannot be assumed passed when it can't be evaluated. Fix the checker/environment, ` +
        `confirm ${manifestRel} is current for the exact pushed commit, then retry.`,
    ].join("\n")
  );
}

// --- git command detection -------------------------------------------------

const LEADING_WRAPPERS = new Set([
  "env",
  "sudo",
  "command",
  "nice",
  "time",
  "timeout",
  "nohup",
  "noglob",
  "xcrun",
  "arch",
  "builtin",
  "exec",
  "if",
  "elif",
  "while",
  "until",
  "!",
  "then",
  "do",
]);
const WRAPPER_VALUE_OPTIONS = Object.freeze({
  env: new Set(["-u", "--unset", "-C", "--chdir", "-S", "--split-string", "-P", "-a", "--argv0"]),
  sudo: new Set([
    "-u",
    "--user",
    "-g",
    "--group",
    "-h",
    "--host",
    "-p",
    "--prompt",
    "-C",
    "--close-from",
    "-R",
    "--chroot",
    "-D",
    "--chdir",
    "-T",
    "--command-timeout",
  ]),
  nice: new Set(["-n", "--adjustment"]),
  time: new Set(["-f", "--format", "-o", "--output"]),
  timeout: new Set(["-k", "--kill-after", "-s", "--signal"]),
  xcrun: new Set(["--sdk", "-sdk", "--toolchain", "-toolchain"]),
  arch: new Set(["-arch", "-d", "-e"]),
});
const WRAPPER_SHORT_VALUE_OPTIONS = Object.freeze({
  env: new Set(["u", "C", "S", "P", "a"]),
  sudo: new Set(["u", "g", "h", "p", "C", "R", "D", "T"]),
  nice: new Set(["n"]),
  time: new Set(["f", "o"]),
  timeout: new Set(["k", "s"]),
  arch: new Set(["d", "e"]),
});
// git GLOBAL options (before the subcommand) that consume the next token.
const GIT_VALUE_OPTS = new Set([
  "-c",
  "--config-env",
  "--namespace",
  "--super-prefix",
  "--exec-path",
]);
// `git push` options that consume the next token (so their value isn't mistaken
// for a remote/refspec positional).
const PUSH_VALUE_OPTS = new Set(["-o", "--push-option", "--receive-pack", "--exec", "--repo"]);
const REPOSITORY_ENV_ASSIGNMENT = /^(?:GIT_DIR|GIT_WORK_TREE|GIT_COMMON_DIR)=/;

// Parse one shell segment. Returns { isGit, isPush, dir, gitDir, workTree, args }
// when the segment invokes git, else null. dir/gitDir/workTree come from git's
// global -C / --git-dir / --work-tree options; args are the tokens after `push`.
function parseSegment(segment, depth = 0) {
  if (depth > 3) return indeterminatePush();
  const withoutRedirections = stripTrailingShellRedirections(segment);
  if (withoutRedirections === null) return null;
  const shellWords = splitSimpleShellWords(withoutRedirections.trim().replace(/^[({]\s*/, ""));
  const tokens = shellWords.map((word) => word.value);
  let i = 0;
  let wrapperDir = null;
  let wrapperDynamic = false;
  // Skip leading `VAR=value` assignments and common command wrappers.
  while (i < tokens.length) {
    if (/^[A-Za-z_][A-Za-z0-9_]*=/.test(tokens[i])) {
      if (/^GIT_CONFIG(?:_|=)/.test(tokens[i]) || REPOSITORY_ENV_ASSIGNMENT.test(tokens[i]))
        wrapperDynamic = true;
      i += 1;
    } else if (LEADING_WRAPPERS.has(path.basename(tokens[i]))) {
      const wrapper = path.basename(tokens[i]);
      i += 1;
      while (i < tokens.length && tokens[i].startsWith("-")) {
        if (tokens[i] === "--") {
          i += 1;
          break;
        }
        const rawOption = tokens[i];
        const { option, inlineValue, inlineValueText } = normalizeWrapperOption(wrapper, rawOption);
        const consumesValue = WRAPPER_VALUE_OPTIONS[wrapper]?.has(option);
        const valueIndex = inlineValue ? i : i + 1;
        const value = inlineValue ? inlineValueText : tokens[valueIndex];
        const splitValueDynamic =
          value !== undefined && (shellWords[valueIndex]?.dynamic === true || /[$`]/.test(value));
        if (
          consumesValue &&
          ((wrapper === "env" && (option === "-C" || option === "--chdir")) ||
            (wrapper === "sudo" && (option === "-D" || option === "--chdir")))
        ) {
          if (value === undefined) return null;
          wrapperDir = composeGitDirectory(wrapperDir, value);
          wrapperDynamic ||= shellWords[valueIndex]?.dynamic === true;
        }
        if (
          wrapper === "env" &&
          (option === "-S" || option === "--split-string") &&
          consumesValue
        ) {
          if (value === undefined) return null;
          if (/[\\'"$`]/.test(value)) return indeterminatePush(wrapperDir);
          const remainderStart = inlineValue ? i + 1 : i + 2;
          const nestedCommand = [
            value,
            ...tokens
              .slice(remainderStart)
              .map((token, offset) =>
                shellWords[remainderStart + offset]?.dynamic
                  ? "$PM_DYNAMIC"
                  : shellQuoteLiteral(token)
              ),
          ].join(" ");
          const nested = parseSegment(nestedCommand, depth + 1);
          if (!nested) {
            if (splitValueDynamic || shellWords.slice(remainderStart).some((word) => word.dynamic))
              return {
                ...indeterminatePush(wrapperDir),
              };
            return null;
          }
          nested.dir = nested.dir ? composeGitDirectory(wrapperDir, nested.dir) : wrapperDir;
          nested.indeterminate ||= wrapperDynamic || splitValueDynamic;
          return nested;
        }
        i += 1;
        if (consumesValue && !inlineValue) i += 1;
      }
      if (wrapper === "timeout" && i < tokens.length) i += 1;
      if (wrapper === "timeout" && tokens[i] === "--") i += 1;
    } else {
      break;
    }
  }
  if (i >= tokens.length) return null;
  const executable = path.basename(tokens[i]);
  const indirectPush = (script) => {
    const root = path.parse(process.cwd()).root;
    const sentinelA = path.join(root, "__pm_indirect_shell_a__", "cwd");
    const sentinelB = path.join(root, "__pm_indirect_shell_b__", "cwd");
    const pushesA = detectGitPushes(script, sentinelA);
    const pushesB = detectGitPushes(script, sentinelB);
    if (pushesA.length === 0 && pushesB.length === 0) return null;
    if (pushesA.length !== 1 || pushesB.length !== 1) return indeterminatePush(wrapperDir);
    const nested = pushesA[0];
    if (nested.cwdOverride === null || pushesB[0].cwdOverride === null)
      return indeterminatePush(wrapperDir);
    let nestedCwd = null;
    if (nested.cwdOverride === pushesB[0].cwdOverride) {
      nestedCwd = nested.cwdOverride;
    } else {
      const relative = path.relative(sentinelA, nested.cwdOverride);
      if (path.resolve(sentinelB, relative) !== pushesB[0].cwdOverride)
        return indeterminatePush(wrapperDir);
      nestedCwd = relative === "" ? null : relative;
    }
    let effectiveDir = wrapperDir;
    if (nestedCwd) effectiveDir = composeGitDirectory(effectiveDir, nestedCwd);
    if (nested.dir) effectiveDir = composeGitDirectory(effectiveDir, nested.dir);
    return {
      isGit: true,
      isPush: true,
      ...nested,
      cwdOverride: undefined,
      dir: effectiveDir,
      indeterminate: nested.indeterminate || wrapperDynamic,
    };
  };
  if (executable === "eval") {
    const script = tokens.slice(i + 1).join(" ");
    if (!script) return null;
    return indirectPush(script);
  }
  if (["bash", "sh", "zsh"].includes(executable)) {
    for (let option = i + 1; option < tokens.length; option += 1) {
      if (!/^-[A-Za-z]+$/.test(tokens[option]) || !tokens[option].slice(1).includes("c")) continue;
      const script = shellWords[option + 1];
      if (!script || script.dynamic) return indeterminatePush(wrapperDir);
      return indirectPush(script.value);
    }
    return null;
  }
  if (executable !== "git") return null;
  i += 1;

  let dir = wrapperDir;
  let gitDir = null;
  let workTree = null;
  let repositoryDynamic = wrapperDynamic;
  while (i < tokens.length) {
    const token = tokens[i];
    if (!token.startsWith("-")) {
      const isPush = token === "push";
      return {
        isGit: true,
        isPush,
        dir,
        gitDir,
        workTree,
        args: isPush ? tokens.slice(i + 1) : [],
        indeterminate:
          repositoryDynamic || (isPush && pushIdentityDynamic(shellWords, tokens, i + 1)),
      };
    }
    if (token === "-C" && i + 1 < tokens.length) {
      dir = composeGitDirectory(dir, tokens[i + 1]);
      repositoryDynamic ||= shellWords[i + 1].dynamic;
      i += 2;
    } else if (token.startsWith("--git-dir=")) {
      gitDir = token.slice("--git-dir=".length);
      repositoryDynamic ||= shellWords[i].dynamic;
      i += 1;
    } else if (token === "--git-dir" && i + 1 < tokens.length) {
      gitDir = tokens[i + 1];
      repositoryDynamic ||= shellWords[i + 1].dynamic;
      i += 2;
    } else if (token.startsWith("--work-tree=")) {
      workTree = token.slice("--work-tree=".length);
      repositoryDynamic ||= shellWords[i].dynamic;
      i += 1;
    } else if (token === "--work-tree" && i + 1 < tokens.length) {
      workTree = tokens[i + 1];
      repositoryDynamic ||= shellWords[i + 1].dynamic;
      i += 2;
    } else if (token.startsWith("-c") && token !== "-c") {
      repositoryDynamic = true;
      i += 1;
    } else if (token.startsWith("--config-env=")) {
      repositoryDynamic = true;
      i += 1;
    } else if (GIT_VALUE_OPTS.has(token)) {
      if (token === "-c" || token === "--config-env") repositoryDynamic = true;
      i += 2;
    } else {
      i += 1;
    }
  }
  return null;
}

function indeterminatePush(dir = null) {
  return {
    isGit: true,
    isPush: true,
    dir,
    gitDir: null,
    workTree: null,
    args: [],
    indeterminate: true,
  };
}

function normalizeWrapperOption(wrapper, rawOption) {
  if (rawOption.startsWith("--")) {
    const equals = rawOption.indexOf("=");
    return {
      option: equals >= 0 ? rawOption.slice(0, equals) : rawOption,
      inlineValue: equals >= 0,
      inlineValueText: equals >= 0 ? rawOption.slice(equals + 1) : null,
    };
  }
  if (rawOption.startsWith("-") && rawOption.length > 2) {
    const body = rawOption.slice(1);
    const valueOptions = WRAPPER_SHORT_VALUE_OPTIONS[wrapper] || new Set();
    for (let index = 0; index < body.length; index += 1) {
      if (!valueOptions.has(body[index])) continue;
      return {
        option: `-${body[index]}`,
        inlineValue: index + 1 < body.length,
        inlineValueText: body.slice(index + 1),
      };
    }
  }
  return { option: rawOption, inlineValue: false, inlineValueText: null };
}

function shellQuoteLiteral(value) {
  return `'${String(value).replace(/'/g, `'\\''`)}'`;
}

function composeGitDirectory(current, next) {
  if (path.isAbsolute(next) || current === null) return next;
  return path.join(current, next);
}

function pushIdentityDynamic(words, tokens, start) {
  for (let i = start; i < tokens.length; i += 1) {
    const token = tokens[i];
    if (!token.startsWith("-")) {
      if (words[i].dynamic) return true;
      continue;
    }
    if (token === "--repo") {
      if (i + 1 < words.length && words[i + 1].dynamic) return true;
      i += 1;
    } else if (token.startsWith("--repo=")) {
      if (words[i].dynamic) return true;
    } else if (PUSH_VALUE_OPTS.has(token)) {
      i += 1;
    }
  }
  return false;
}

function splitSimpleShellWords(input) {
  const syntax = lexShellCharacters(input);
  if (!syntax.closed) return [];
  const words = [];
  let current = "";
  let active = false;
  let dynamic = false;
  const pushWord = () => {
    words.push({ value: current, dynamic });
    current = "";
    active = false;
    dynamic = false;
  };
  let substitutionDepth = 0;
  for (let offset = 0; offset < syntax.characters.length; offset += 1) {
    const entry = syntax.characters[offset];
    if (entry.marker) {
      active = true;
      if (entry.quote === "`") dynamic = true;
      continue;
    }
    const next = syntax.characters[offset + 1];
    if (
      !entry.quote &&
      !entry.escaped &&
      entry.char === "$" &&
      next &&
      !next.quote &&
      !next.escaped &&
      next.char === "(" &&
      next.index === entry.index + 1
    ) {
      current += "$(";
      active = true;
      dynamic = true;
      substitutionDepth += 1;
      offset += 1;
      continue;
    }
    if (substitutionDepth > 0) {
      current += entry.char;
      active = true;
      if (!entry.quote && !entry.escaped && entry.char === "(") substitutionDepth += 1;
      else if (!entry.quote && !entry.escaped && entry.char === ")") substitutionDepth -= 1;
      continue;
    }
    if (!entry.quote && !entry.escaped && /\s/.test(entry.char)) {
      if (active) pushWord();
    } else {
      if (
        (!entry.escaped && entry.char === "$" && entry.quote !== "'") ||
        (!entry.quote && !entry.escaped && "*?[]{}".includes(entry.char)) ||
        (!entry.quote && !entry.escaped && entry.char === "~" && !active)
      )
        dynamic = true;
      current += entry.char;
      active = true;
    }
  }
  if (active) pushWord();
  return words;
}

// Scan a full command string for a `git push`. Backslash-newline is a shell
// CONTINUATION — join it first so a wrapped push stays one command (bare newlines
// remain genuine separators, so a push on a later line is never missed). Tracks a
// leading `cd <dir>` so `cd repo && git push` gates the right repo.
function detectGitPushes(command, baseCwd) {
  const joined = command.replace(/\\\r?\n/g, " ");
  let states = [{ cwd: path.resolve(baseCwd), succeeded: true }];
  const subshells = [];
  const pushes = [];
  let operator = null;
  let pipelineBaseStates = null;
  let cursor = 0;

  const visit = (segment) => {
    const trimmed = segment.trim();
    if (!trimmed) return;
    const { executes, skips } = partitionShellStates(states, operator);
    const directoryChange = parseDirectoryChange(trimmed);
    if (directoryChange.recognized) {
      states = dedupeShellStates([
        ...skips,
        ...executes.flatMap((state) => [
          {
            cwd:
              directoryChange.target === null ||
              (state.cwd === null && !path.isAbsolute(directoryChange.target))
                ? null
                : path.resolve(
                    state.cwd || path.parse(directoryChange.target).root,
                    directoryChange.target
                  ),
            succeeded: true,
          },
          { cwd: state.cwd, succeeded: false },
        ]),
      ]);
      return;
    }
    const parsed = parseSegment(trimmed);
    if (parsed && parsed.isPush) {
      for (const state of executes)
        pushes.push({
          dir: parsed.dir,
          gitDir: parsed.gitDir,
          workTree: parsed.workTree,
          cwdOverride: state.cwd,
          args: parsed.args,
          indeterminate: parsed.indeterminate,
        });
    }
    states = dedupeShellStates([
      ...skips,
      ...executes.flatMap((state) => [
        { cwd: state.cwd, succeeded: true },
        { cwd: state.cwd, succeeded: false },
      ]),
    ]);
  };

  for (const shellToken of scanShellTokens(joined)) {
    const statesBeforeSegment = states.map((state) => ({ ...state }));
    visit(joined.slice(cursor, shellToken.index));
    const token = shellToken.value;
    if (pipelineBaseStates) {
      const outcomes = new Set(states.map((state) => state.succeeded));
      states = dedupeShellStates(
        pipelineBaseStates.flatMap((state) =>
          [...outcomes].map((succeeded) => ({ cwd: state.cwd, succeeded }))
        )
      );
      if (token !== "|") pipelineBaseStates = null;
    }
    if (token === "|") {
      pipelineBaseStates ||= statesBeforeSegment;
      states = dedupeShellStates(
        statesBeforeSegment.flatMap((state) => [
          { cwd: state.cwd, succeeded: true },
          { cwd: state.cwd, succeeded: false },
        ])
      );
      operator = token;
      cursor = shellToken.end;
      continue;
    }
    if (token === "&") {
      states = dedupeShellStates(
        statesBeforeSegment.flatMap((state) => [
          { cwd: state.cwd, succeeded: true },
          { cwd: state.cwd, succeeded: false },
        ])
      );
      operator = token;
      cursor = shellToken.end;
      continue;
    }
    if (token === "(") {
      const { executes, skips } = partitionShellStates(states, operator);
      subshells.push({ executes, skips });
      states = executes.map((state) => ({ cwd: state.cwd, succeeded: true }));
      operator = null;
    } else if (token === ")") {
      const frame = subshells.pop();
      if (frame) {
        const outcomes = new Set(states.map((state) => state.succeeded));
        states = dedupeShellStates([
          ...frame.skips,
          ...frame.executes.flatMap((entry) =>
            [...outcomes].map((succeeded) => ({ cwd: entry.cwd, succeeded }))
          ),
        ]);
      }
      operator = null;
    } else if (token === "{" || token === "}") {
      // Brace groups execute in the current shell. The delimiter itself does
      // not change cwd; commands inside continue through the same state set.
    } else {
      operator = token;
    }
    cursor = shellToken.end;
  }
  visit(joined.slice(cursor));
  return pushes;
}

function parseDirectoryChange(segment) {
  const withoutControlKeywords = segment.replace(/^\s*(?:(?:then|do|else)\b\s*)+/i, "");
  const commandText = stripTrailingShellRedirections(withoutControlKeywords);
  if (commandText === null)
    return {
      recognized: /^(?:(?:builtin|command)\s+)?(?:cd|pushd|popd)\b/.test(withoutControlKeywords),
      target: null,
    };
  const match = commandText.match(
    /^(?:(?:builtin|command)\s+)?(cd|pushd|popd)(?:\s+(-P|--))?(?:\s+(.*?))?\s*$/
  );
  if (!match) return { recognized: false, target: null };
  const [, command, option, operand] = match;
  if (command === "popd") return { recognized: true, target: null };
  if (command === "pushd" && (option || operand === undefined || /^[+-]\d+$/.test(operand)))
    return { recognized: true, target: null };
  if (operand === undefined || operand === "")
    return { recognized: true, target: process.env.HOME ? path.resolve(process.env.HOME) : null };
  if (operand === "-") return { recognized: true, target: null };
  return { recognized: true, target: decodeSimpleShellWord(operand) };
}

function stripTrailingShellRedirections(segment) {
  let commandText = segment;
  let leading;
  do {
    leading = commandText;
    commandText = commandText.replace(
      /^\s*(?:\d*(?:>>?|<{1,3})|&>>?)\s*(?:"[^"]*"|'[^']*'|[^\s<>]+)\s+/,
      ""
    );
  } while (commandText !== leading);
  const syntax = lexShellCharacters(commandText);
  if (!syntax.closed) return null;
  let redirectIndex = -1;
  for (const entry of syntax.characters) {
    if (!entry.quote && !entry.escaped && (entry.char === ">" || entry.char === "<")) {
      redirectIndex = entry.index;
      const aggregate = entry.char === ">" && commandText[redirectIndex - 1] === "&";
      if (aggregate) redirectIndex -= 1;
      else
        while (redirectIndex > 0 && /\d/.test(commandText[redirectIndex - 1])) redirectIndex -= 1;
      if (!aggregate && redirectIndex > 0 && !/\s/.test(commandText[redirectIndex - 1]))
        redirectIndex = entry.index;
      break;
    }
  }
  if (redirectIndex < 0) return commandText;
  const suffix = commandText.slice(redirectIndex);
  if (!/^(?:(?:\d*(?:>>?|<{1,3})|&>>?)\s*(?:"[^"]*"|'[^']*'|[^\s<>]+)\s*)+$/.test(suffix))
    return null;
  return commandText.slice(0, redirectIndex).trimEnd();
}

function decodeSimpleShellWord(raw) {
  const syntax = lexShellCharacters(raw);
  if (!syntax.closed || syntax.sawBacktick) return null;
  let value = "";
  for (const entry of syntax.characters) {
    const { char, quote, escaped } = entry;
    if (
      (!quote && !escaped && /\s/.test(char)) ||
      (char === "$" && quote !== "'") ||
      (!quote && !escaped && char === "~" && value === "") ||
      (!quote && !escaped && "*?[]{}".includes(char))
    )
      return null;
    value += char;
  }
  return value === "" ? null : value;
}

function scanShellTokens(command) {
  const tokens = [];
  const syntax = lexShellCharacters(command);
  for (let offset = 0; offset < syntax.characters.length; offset += 1) {
    const entry = syntax.characters[offset];
    if (entry.quote || entry.escaped) continue;
    const next = syntax.characters[offset + 1];
    if (
      entry.char === "$" &&
      next &&
      !next.quote &&
      !next.escaped &&
      next.char === "(" &&
      next.index === entry.index + 1
    ) {
      let depth = 1;
      while (offset + 2 < syntax.characters.length && depth > 0) {
        offset += 1;
        const nested = syntax.characters[offset + 1];
        if (!nested.quote && !nested.escaped && nested.char === "(") depth += 1;
        else if (!nested.quote && !nested.escaped && nested.char === ")") depth -= 1;
      }
      offset += 1;
      continue;
    }
    const pair =
      next && !next.quote && !next.escaped && next.index === entry.index + 1
        ? `${entry.char}${next.char}`
        : "";
    if (pair === "&&" || pair === "||") {
      tokens.push({ value: pair, index: entry.index, end: next.index + 1 });
      offset += 1;
      continue;
    }
    const char = entry.char;
    const i = entry.index;
    if (
      char === "&" &&
      ((/[<>]/.test(command[i - 1] || "") && /[\d-]/.test(command[i + 1] || "")) ||
        command[i + 1] === ">")
    )
      continue;
    if (char === "{" || char === "}") {
      const boundary = (value) =>
        value === undefined || /\s/.test(value) || ";|&(){}".includes(value);
      if (boundary(command[i - 1]) && boundary(command[i + 1]))
        tokens.push({ value: char, index: i, end: i + 1 });
      continue;
    }
    if (";\n|&()".includes(char)) tokens.push({ value: char, index: i, end: i + 1 });
  }
  return tokens;
}

function lexShellCharacters(input) {
  const characters = [];
  let quote = null;
  let sawBacktick = false;
  for (let i = 0; i < input.length; i += 1) {
    const char = input[i];
    if (quote) {
      if (char === quote) {
        quote = null;
      } else if (char === "\\" && quote !== "'") {
        if (i + 1 >= input.length) return { characters, closed: false, sawBacktick };
        i += 1;
        characters.push({ char: input[i], index: i, quote, escaped: true });
      } else {
        characters.push({ char, index: i, quote, escaped: false });
      }
      continue;
    }
    if (char === "'" || char === '"' || char === "`") {
      quote = char;
      if (char === "`") sawBacktick = true;
      characters.push({ char: "", index: i, quote, escaped: false, marker: true });
      continue;
    }
    if (char === "\\") {
      if (i + 1 >= input.length) return { characters, closed: false, sawBacktick };
      i += 1;
      characters.push({ char: input[i], index: i, quote: null, escaped: true });
      continue;
    }
    characters.push({ char, index: i, quote: null, escaped: false });
  }
  return { characters, closed: quote === null, sawBacktick };
}

function containsPushCommandSubstitution(command) {
  const pushInside = (body) =>
    detectGitPushes(body, process.cwd()).length > 0 || containsPushCommandSubstitution(body);
  const findClosing = (start) => {
    let depth = 1;
    let quote = null;
    for (let index = start; index < command.length; index += 1) {
      const char = command[index];
      if (char === "\\") {
        index += 1;
        continue;
      }
      if (quote) {
        if (char === quote) quote = null;
        continue;
      }
      if (char === "'" || char === '"' || char === "`") {
        quote = char;
        continue;
      }
      if (char === "(") depth += 1;
      else if (char === ")" && --depth === 0) return index;
    }
    return -1;
  };
  let quote = null;
  for (let index = 0; index < command.length; index += 1) {
    const char = command[index];
    if (char === "\\") {
      index += 1;
      continue;
    }
    if (char === "'" && quote !== '"') {
      quote = quote === "'" ? null : "'";
      continue;
    }
    if (quote === "'") continue;
    if (char === '"') {
      quote = quote === '"' ? null : '"';
      continue;
    }
    if (char === "`") {
      const end = command.indexOf("`", index + 1);
      if (end < 0 || pushInside(command.slice(index + 1, end))) return true;
      index = end;
      continue;
    }
    if (char === "$" && command[index + 1] === "(") {
      const end = findClosing(index + 2);
      if (end < 0 || pushInside(command.slice(index + 2, end))) return true;
      index = end;
    }
  }
  return false;
}

function containsUnsupportedHeredoc(command) {
  const syntax = lexShellCharacters(command);
  for (let i = 0; i + 1 < syntax.characters.length; i += 1) {
    const previous = syntax.characters[i - 1];
    const first = syntax.characters[i];
    const second = syntax.characters[i + 1];
    const third = syntax.characters[i + 2];
    if (
      !first.quote &&
      !first.escaped &&
      first.char === "<" &&
      !(
        previous &&
        !previous.quote &&
        !previous.escaped &&
        previous.char === "<" &&
        previous.index === first.index - 1
      ) &&
      !second.quote &&
      !second.escaped &&
      second.char === "<" &&
      second.index === first.index + 1 &&
      !(
        third &&
        !third.quote &&
        !third.escaped &&
        third.char === "<" &&
        third.index === second.index + 1
      )
    )
      return true;
  }
  return false;
}

function commandWithoutHeredocPayloads(command) {
  const lines = command.split(/\r?\n/);
  const output = [];
  const pending = [];
  for (const line of lines) {
    if (pending.length > 0) {
      const current = pending[0];
      const candidate = current.stripTabs ? line.replace(/^\t+/, "") : line;
      if (candidate === current.delimiter) pending.shift();
      continue;
    }
    output.push(line);
    if (line.includes("<<<")) continue;
    for (const match of line.matchAll(/<<(-?)\s*(['"]?)([A-Za-z_][A-Za-z0-9_]*)\2/g))
      pending.push({ stripTabs: match[1] === "-", delimiter: match[3] });
  }
  return output.join("\n");
}

function partitionShellStates(states, operator) {
  const executes = [];
  const skips = [];
  for (const state of states) {
    const shouldExecute =
      operator === "&&" ? state.succeeded : operator === "||" ? !state.succeeded : true;
    (shouldExecute ? executes : skips).push(state);
  }
  return { executes, skips };
}

function dedupeShellStates(states) {
  const unique = new Map();
  for (const state of states)
    unique.set(`${state.cwd === null ? "<unknown>" : state.cwd}\0${state.succeeded}`, state);
  return [...unique.values()];
}

// Destination branch a refspec writes to, or a sentinel for delete/tag/none.
function refspecDest(spec) {
  let s = spec.startsWith("+") ? spec.slice(1) : spec;
  if (s === ":") return { kind: "matching" };
  if (s.startsWith(":")) return { kind: "delete" };
  const colon = s.indexOf(":");
  let dst = colon >= 0 ? s.slice(colon + 1) : s;
  if (dst === "") return { kind: "delete" };
  if (dst.startsWith("refs/tags/")) return { kind: "tag" };
  if (dst.startsWith("refs/heads/")) dst = dst.slice("refs/heads/".length);
  return { kind: "branch", dst };
}

function branchPatternCapture(pattern, branch) {
  const wildcard = pattern.indexOf("*");
  if (wildcard < 0) return pattern === branch ? "" : null;
  if (pattern.indexOf("*", wildcard + 1) >= 0) return null;
  const prefix = pattern.slice(0, wildcard);
  const suffix = pattern.slice(wildcard + 1);
  if (!branch.startsWith(prefix) || !branch.endsWith(suffix)) return null;
  if (branch.length < prefix.length + suffix.length) return null;
  return branch.slice(prefix.length, branch.length - suffix.length);
}

function sessionBranchRefspecSource(raw, sessionBranch, provenance = null) {
  const spec = raw.startsWith("+") ? raw.slice(1) : raw;
  const dest = refspecDest(spec);
  if (dest.kind === "matching")
    return {
      error: `${provenance ? `${provenance} ` : ""}matching multi-ref push cannot be bound to one source commit`,
    };
  if (dest.kind !== "branch") return null;
  const capture = branchPatternCapture(dest.dst, sessionBranch);
  const targetsSession = dest.dst === "HEAD" || dest.dst === "@" || capture !== null;
  if (!targetsSession) return null;
  const colon = spec.indexOf(":");
  const source = colon >= 0 ? spec.slice(0, colon) : spec;
  if (!source) return { error: "session-branch deletion has no source commit" };
  if (source.includes("*") || dest.dst.includes("*"))
    return {
      error: `${provenance ? `${provenance} ` : ""}wildcard refspec can expand the session-branch push to multiple updates`,
    };
  return { source };
}

// Does this `git push` update the SESSION BRANCH's ref? Only those pushes are
// gated. Tag pushes, deletions, and cross-branch pushes are out of scope.
function parsePushArguments(args) {
  const positionals = [];
  let sawDelete = false;
  let sawTags = false;
  let allBranches = false;
  let mirror = false;
  let followTags = null;
  let remote = null;
  let remoteSuppliedByOption = false;
  let optionsEnded = false;
  for (let i = 0; i < args.length; i += 1) {
    const token = args[i];
    if (!optionsEnded && token === "--") {
      optionsEnded = true;
      continue;
    }
    if (!optionsEnded && token.startsWith("-")) {
      if (token === "--delete" || token === "-d") sawDelete = true;
      else if (token === "--no-delete") sawDelete = false;
      else if (token === "--tags") sawTags = true;
      else if (token === "--no-tags") sawTags = false;
      else if (token === "--all" || token === "--branches") allBranches = true;
      else if (token === "--no-all" || token === "--no-branches") allBranches = false;
      else if (token === "--mirror") mirror = true;
      else if (token === "--no-mirror") mirror = false;
      else if (token === "--follow-tags") followTags = true;
      else if (token === "--no-follow-tags") followTags = false;
      else if (token === "--repo") {
        remoteSuppliedByOption = true;
        remote = args[i + 1] || null;
        i += 1;
      } else if (token.startsWith("--repo=")) {
        remoteSuppliedByOption = true;
        remote = token.slice("--repo=".length) || null;
      } else if (PUSH_VALUE_OPTS.has(token)) i += 1; // skip its value
      continue;
    }
    positionals.push(token);
  }
  return {
    sawDelete,
    sawTags,
    sawAllOrMirror: allBranches || mirror,
    followTags,
    remote: remoteSuppliedByOption ? remote : positionals[0] || null,
    refspecs: positionals.slice(remoteSuppliedByOption ? 0 : 1),
  };
}

function sessionBranchPushSource(
  repoDir,
  args,
  sessionBranch,
  effectiveRefspecs = null,
  refspecSource = null,
  gitDir = null,
  effectiveExpansionError = null
) {
  const parsed = parsePushArguments(args);
  const { sawAllOrMirror } = parsed;
  const refspecs = effectiveRefspecs || parsed.refspecs;
  const provenance = refspecSource || (effectiveRefspecs ? "effective" : "command line");
  if (sawAllOrMirror)
    return { error: "multi-ref --all/--mirror push cannot be bound to one source commit" };
  if (effectiveExpansionError) return { error: effectiveExpansionError };
  const expansionError = sessionPushExpansionError(repoDir, args, gitDir);
  if (expansionError) return { error: expansionError };
  if (refspecs.length > 1)
    return {
      error: `${provenance} multi-ref push cannot be bound to one source commit`,
    };
  if (refspecs.length === 0) return { source: "HEAD" };
  const sources = [];
  for (const raw of refspecs) {
    const match = sessionBranchRefspecSource(raw, sessionBranch, provenance);
    if (!match) continue;
    if (match.error) return match;
    sources.push(match.source);
  }
  if (sources.length !== 1)
    return { error: "session branch push must resolve to exactly one source refspec" };
  return { source: sources[0] };
}

// --- git helpers -----------------------------------------------------------

function gitCapture(repoDir, args, gitDir = null) {
  const prefix = gitDir ? [`--git-dir=${gitDir}`, `--work-tree=${repoDir}`] : ["-C", repoDir];
  const result = spawnSync("git", [...prefix, ...args], {
    encoding: "utf8",
    maxBuffer: MAX_BUFFER,
  });
  if (!result || result.status !== 0) return "";
  return (result.stdout || "").trim();
}

function gitConfigValues(repoDir, key, gitDir = null) {
  const prefix = gitDir ? [`--git-dir=${gitDir}`, `--work-tree=${repoDir}`] : ["-C", repoDir];
  const result = spawnSync("git", [...prefix, "config", "--null", "--get-all", key], {
    encoding: "utf8",
    maxBuffer: MAX_BUFFER,
  });
  if (!result || (result.status !== 0 && result.status !== 1))
    return { error: `cannot read Git configuration ${key}` };
  if (result.status === 1) return { values: [] };
  const values = (result.stdout || "").split("\0");
  if (values.at(-1) === "") values.pop();
  return { values };
}

function gitConfigBoolean(repoDir, key, gitDir = null) {
  const prefix = gitDir ? [`--git-dir=${gitDir}`, `--work-tree=${repoDir}`] : ["-C", repoDir];
  const result = spawnSync("git", [...prefix, "config", "--type=bool", "--get-all", key], {
    encoding: "utf8",
    maxBuffer: MAX_BUFFER,
  });
  if (!result || (result.status !== 0 && result.status !== 1))
    return { error: `cannot read Git boolean configuration ${key}` };
  if (result.status === 1) return { value: false };
  const values = (result.stdout || "").trim().split(/\r?\n/).filter(Boolean);
  const value = values.at(-1);
  if (value !== "true" && value !== "false")
    return { error: `Git configuration ${key} is not a boolean` };
  return { value: value === "true" };
}

function currentBranch(repoDir, gitDir = null) {
  const shown = gitCapture(repoDir, ["branch", "--show-current"], gitDir);
  if (shown) return shown;
  const abbrev = gitCapture(repoDir, ["rev-parse", "--abbrev-ref", "HEAD"], gitDir);
  return abbrev && abbrev !== "HEAD" ? abbrev : "";
}

function resolvePushRemote(repoDir, args, branch, gitDir = null) {
  let remote = parsePushArguments(args).remote;
  if (!remote) {
    remote =
      gitCapture(repoDir, ["config", "--get", `branch.${branch}.pushRemote`], gitDir) ||
      gitCapture(repoDir, ["config", "--get", "remote.pushDefault"], gitDir) ||
      gitCapture(repoDir, ["config", "--get", `branch.${branch}.remote`], gitDir) ||
      "origin";
  }
  const configured = gitCapture(repoDir, ["remote"], gitDir).split(/\r?\n/).filter(Boolean);
  if (remote === "." || !configured.includes(remote))
    return { error: `push destination ${remote} is not a configured named remote` };
  if (
    !gitCapture(repoDir, ["config", "--get-all", `remote.${remote}.pushurl`], gitDir) &&
    !gitCapture(repoDir, ["config", "--get-all", `remote.${remote}.url`], gitDir)
  )
    return { error: `push destination ${remote} is not a configured named remote` };
  return { remote };
}

function sessionPushExpansionError(repoDir, args, gitDir = null) {
  const parsed = parsePushArguments(args);
  if (parsed.sawTags)
    return "command line --tags expands the session-branch push to additional tag updates";
  if (parsed.followTags === true)
    return "command line --follow-tags can expand the session-branch push to additional tag updates";

  if (parsed.followTags !== false) {
    const configuredFollowTags = gitConfigBoolean(repoDir, "push.followTags", gitDir);
    if (configuredFollowTags.error) return configuredFollowTags.error;
    if (configuredFollowTags.value)
      return "configured push.followTags expands the session-branch push to additional tag updates";
  }

  return null;
}

function upstreamPushRefspec(repoDir, destinationRemote, branch, policy, gitDir = null) {
  const remoteConfig = gitConfigValues(repoDir, `branch.${branch}.remote`, gitDir);
  if (remoteConfig.error) return remoteConfig;
  const upstreamRemote = remoteConfig.values.at(-1) || null;
  const mergeConfig = gitConfigValues(repoDir, `branch.${branch}.merge`, gitDir);
  if (mergeConfig.error) return mergeConfig;

  if (policy === "simple" && upstreamRemote && upstreamRemote !== destinationRemote)
    return { refspecs: [`HEAD:refs/heads/${branch}`], source: "push.default=simple" };
  if (!upstreamRemote)
    return { error: `push.default=${policy} requires an upstream remote for ${branch}` };
  if (upstreamRemote !== destinationRemote)
    return {
      error: `push.default=${policy} targets upstream remote ${upstreamRemote}, not ${destinationRemote}`,
    };
  if (mergeConfig.values.length !== 1)
    return {
      error: `push.default=${policy} requires exactly one upstream branch for ${branch}`,
    };
  const mergeRef = mergeConfig.values[0];
  if (!mergeRef.startsWith("refs/heads/") || mergeRef.length === "refs/heads/".length)
    return { error: `push.default=${policy} has an unsupported upstream ref ${mergeRef}` };
  const destinationBranch = mergeRef.slice("refs/heads/".length);
  if (policy === "simple" && destinationBranch !== branch)
    return {
      error: `push.default=simple refuses renamed upstream ${destinationBranch} for ${branch}`,
    };
  return { refspecs: [`HEAD:${mergeRef}`], source: `push.default=${policy}` };
}

function implicitPushRefspecs(repoDir, destinationRemote, branch, gitDir = null) {
  const configuredDefault = gitConfigValues(repoDir, "push.default", gitDir);
  if (configuredDefault.error) return configuredDefault;
  const rawPolicy = configuredDefault.values.at(-1);
  const policy = rawPolicy === undefined ? "simple" : rawPolicy.toLowerCase();
  if (policy === "current")
    return { refspecs: [`HEAD:refs/heads/${branch}`], source: "push.default=current" };
  if (policy === "upstream" || policy === "tracking")
    return upstreamPushRefspec(repoDir, destinationRemote, branch, policy, gitDir);
  if (policy === "simple")
    return upstreamPushRefspec(repoDir, destinationRemote, branch, policy, gitDir);
  if (policy === "matching")
    return { error: "push.default=matching is an ambiguous multi-ref push" };
  if (policy === "nothing") return { error: "push.default=nothing has no implicit refspec" };
  return { error: `unsupported push.default value ${rawPolicy === "" ? "<empty>" : rawPolicy}` };
}

function effectivePushRefspecs(repoDir, args, branch, gitDir = null) {
  const parsed = parsePushArguments(args);
  if (parsed.refspecs.length > 0 || parsed.sawDelete || parsed.sawTags || parsed.sawAllOrMirror)
    return { refspecs: null, source: "command line" };
  const destination = resolvePushRemote(repoDir, args, branch, gitDir);
  if (destination.error) return destination;
  const configured = gitConfigValues(repoDir, `remote.${destination.remote}.push`, gitDir);
  if (configured.error) return configured;
  if (configured.values.length > 0) {
    if (configured.values.some((value) => value === ""))
      return { error: `remote.${destination.remote}.push contains an empty refspec` };
    if (configured.values.some((value) => refspecDest(value).kind === "matching"))
      return { error: `remote.${destination.remote}.push contains a matching multi-ref push` };
    return { refspecs: configured.values, source: "configured", remote: destination.remote };
  }
  const configuredMirror = gitConfigBoolean(repoDir, `remote.${destination.remote}.mirror`, gitDir);
  if (configuredMirror.error) return configuredMirror;
  if (configuredMirror.value)
    return {
      refspecs: ["refs/heads/*:refs/heads/*"],
      source: `configured remote.${destination.remote}.mirror`,
      remote: destination.remote,
      expansionError: `configured remote.${destination.remote}.mirror expands the session-branch push to multiple ref updates`,
    };
  if (!branch) return { error: "implicit push from detached HEAD" };
  return {
    ...implicitPushRefspecs(repoDir, destination.remote, branch, gitDir),
    remote: destination.remote,
  };
}

function pushDestinationShape(args, currentBranch, effectiveRefspecs = null) {
  const parsed = parsePushArguments(args);
  if (parsed.sawDelete)
    return { branches: [], patterns: [], broad: false, unresolvedCurrent: false };
  const refspecs = effectiveRefspecs || parsed.refspecs;
  if (parsed.sawAllOrMirror)
    return { branches: [], patterns: [], broad: true, unresolvedCurrent: false };
  if (refspecs.length === 0) {
    if (parsed.sawTags)
      return { branches: [], patterns: [], broad: false, unresolvedCurrent: false };
    if (!currentBranch) return { error: "implicit push from detached HEAD" };
    return { branches: [currentBranch], patterns: [], broad: false, unresolvedCurrent: false };
  }

  const branches = new Set();
  const patterns = new Set();
  let broad = false;
  let unresolvedCurrent = false;
  for (const raw of refspecs) {
    const dest = refspecDest(raw);
    if (dest.kind === "matching") {
      broad = true;
      continue;
    }
    if (dest.kind !== "branch") continue;
    if (dest.dst === "HEAD" || dest.dst === "@") {
      if (currentBranch) branches.add(currentBranch);
      else unresolvedCurrent = true;
    } else if (dest.dst.includes("*")) {
      patterns.add(dest.dst);
    } else {
      branches.add(dest.dst);
    }
  }
  return { branches: [...branches], patterns: [...patterns], broad, unresolvedCurrent };
}

function canonicalSessionsDirectory(repoDir) {
  let root;
  try {
    root = fs.realpathSync(path.resolve(repoDir));
  } catch (error) {
    if (error.code === "ENOENT") return null;
    throw error;
  }
  let current = root;
  for (const part of [".pm", "dev-sessions"]) {
    current = path.join(current, part);
    let stat;
    try {
      stat = fs.lstatSync(current);
    } catch (error) {
      if (error.code === "ENOENT") return null;
      throw error;
    }
    if (stat.isSymbolicLink()) throw new Error(`${path.relative(root, current)} is a symlink`);
    if (!stat.isDirectory()) throw new Error(`${path.relative(root, current)} is not a directory`);
  }
  return { root, directory: current };
}

function loadCanonicalSessionCandidate(located, slug, stat) {
  const candidate = { slug, directory: path.join(located.directory, slug), session: null };
  if (stat.isSymbolicLink()) {
    candidate.error = "canonical session directory is a symlink";
    return candidate;
  }
  if (!stat.isDirectory()) {
    candidate.error = "canonical session candidate is not a directory";
    return candidate;
  }

  const relative = path.join(".pm", "dev-sessions", slug, "session.json");
  try {
    fs.lstatSync(path.join(candidate.directory, "session.json"));
  } catch (error) {
    if (error.code === "ENOENT") {
      candidate.missingSession = true;
      return candidate;
    }
    candidate.error = error.message;
    return candidate;
  }
  try {
    const file = readProjectInput(located.root, relative, MAX_SESSION_BYTES);
    const session = JSON.parse(file.bytes.toString("utf8"));
    const validation = validateSession(session);
    if (validation.length > 0)
      throw new Error(
        validation
          .slice(0, 3)
          .map((item) => `${item.path}: ${item.message}`)
          .join("; ")
      );
    if (session.slug !== slug)
      throw new Error(`session.slug ${session.slug} must equal directory ${slug}`);
    const derived = loadDeriveSessionSlug()(session.source.branch);
    if (derived !== slug)
      throw new Error(
        `session.source.branch ${session.source.branch} derives slug ${derived}, not ${slug}`
      );
    candidate.session = session;
  } catch (error) {
    candidate.error = error.message;
  }
  return candidate;
}

function loadCanonicalSessionIndex(repoDir, exactSlugs = null) {
  const located = canonicalSessionsDirectory(repoDir);
  if (!located) return { sessions: [], candidates: new Map(), legacyMarkers: [] };
  const entries = [];
  const legacyMarkers = [];
  if (exactSlugs) {
    for (const slug of new Set(exactSlugs)) {
      try {
        entries.push({ slug, stat: fs.lstatSync(path.join(located.directory, slug)) });
      } catch (error) {
        if (error.code !== "ENOENT") throw error;
      }
    }
  } else {
    const directory = fs.opendirSync(located.directory);
    let scannedEntries = 0;
    try {
      let entry;
      while ((entry = directory.readSync()) !== null) {
        scannedEntries += 1;
        if (scannedEntries > MAX_SESSION_DIRECTORIES)
          throw new Error(`canonical session inventory exceeds ${MAX_SESSION_DIRECTORIES} entries`);
        if (!entry.isDirectory() && !entry.isSymbolicLink() && entry.name.endsWith(".md")) continue;
        if (
          !entry.isDirectory() &&
          !entry.isSymbolicLink() &&
          (entry.name === "current.gates.json" || entry.name.endsWith(".gates.json"))
        )
          legacyMarkers.push(entry.name);
        else entries.push({ slug: entry.name, stat: entry });
      }
    } finally {
      directory.closeSync();
    }
  }

  const sessions = [];
  const candidates = new Map();
  for (const entry of entries) {
    const slug = entry.slug;
    if (candidates.has(slug)) throw new Error(`duplicate canonical session directory ${slug}`);
    const candidate = loadCanonicalSessionCandidate(located, slug, entry.stat);
    candidates.set(slug, candidate);
    if (candidate.session) sessions.push(candidate);
  }
  return { sessions, candidates, legacyMarkers };
}

function destinationMatchesShape(branch, shape) {
  if (shape.broad || shape.branches.includes(branch)) return true;
  return shape.patterns.some((pattern) => branchPatternCapture(pattern, branch) !== null);
}

function selectCanonicalSessionTargets(repoDir, shape, currentBranch) {
  if (
    !shape.broad &&
    !shape.unresolvedCurrent &&
    shape.branches.length === 0 &&
    shape.patterns.length === 0
  )
    return { targets: [] };
  const wildcardSelection = shape.broad || shape.patterns.length > 0;
  const deriveSlug = loadDeriveSessionSlug();
  const needsFullInventory = wildcardSelection || shape.unresolvedCurrent;
  const index = loadCanonicalSessionIndex(
    repoDir,
    needsFullInventory ? null : shape.branches.map((branch) => deriveSlug(branch))
  );
  if ((wildcardSelection || shape.unresolvedCurrent) && index.legacyMarkers.length > 0)
    return {
      error: `cannot classify broad push while inspection-only legacy gate markers exist: ${index.legacyMarkers.slice(0, 5).join(", ")}`,
    };
  if (wildcardSelection) {
    const invalid = [...index.candidates.values()].find(
      (candidate) => candidate.error || candidate.missingSession
    );
    if (invalid)
      return {
        error: `cannot classify wildcard push against canonical session ${invalid.slug}: ${invalid.error || "canonical session.json is missing"}`,
      };
  }
  if (shape.unresolvedCurrent) {
    const invalid = [...index.candidates.values()].find(
      (candidate) => candidate.error || candidate.missingSession
    );
    if (invalid)
      return {
        error: `cannot resolve detached destination against canonical session ${invalid.slug}: ${invalid.error || "canonical session.json is missing"}`,
      };
    if (index.sessions.length > 0)
      return {
        error: `detached destination cannot be resolved against canonical PM session branches: ${index.sessions.map((item) => item.session.source.branch).join(", ")}`,
      };
  }

  const matched = new Map();
  for (const branch of shape.branches) {
    const slug = deriveSlug(branch);
    const candidate = index.candidates.get(slug);
    if (candidate) {
      if (candidate.missingSession) {
        matched.set(branch, { branch, slug, session: null });
        continue;
      }
      if (candidate.error) {
        return { error: `cannot validate canonical session ${slug}: ${candidate.error}` };
      }
      if (candidate.session.source.branch !== branch)
        return {
          error: `canonical session slug collision: ${slug} belongs to ${candidate.session.source.branch}, not destination ${branch}`,
        };
      matched.set(branch, { branch, slug, session: candidate.session });
      continue;
    }
    const sessionsDir = path.join(repoDir, ".pm", "dev-sessions");
    const hasLegacy = fs.existsSync(path.join(sessionsDir, `${slug}.gates.json`));
    const hasCurrent =
      branch === currentBranch && fs.existsSync(path.join(sessionsDir, "current.gates.json"));
    if (hasLegacy || hasCurrent) matched.set(branch, { branch, slug, session: null });
  }

  for (const candidate of index.sessions) {
    if (destinationMatchesShape(candidate.session.source.branch, shape))
      matched.set(candidate.session.source.branch, {
        branch: candidate.session.source.branch,
        slug: candidate.slug,
        session: candidate.session,
      });
  }

  const targets = [...matched.values()];
  if (targets.length > 1)
    return {
      error: `push updates multiple canonical PM session branches: ${targets.map((item) => item.branch).join(", ")}`,
    };
  return { targets };
}

// deriveSessionSlug is the single source of truth for branch -> manifest-name
// normalization, shared with skills/hooks and .githooks/pre-push.
function loadDeriveSessionSlug() {
  return require(CHECKER).deriveSessionSlug;
}

function checkoutPointsToGitDir(checkoutGitPath, gitDir) {
  try {
    const reciprocal = fs.readFileSync(checkoutGitPath, "utf8").trim();
    const match = /^gitdir:\s*(.+)$/i.exec(reciprocal);
    return (
      match &&
      fs.realpathSync(path.resolve(path.dirname(checkoutGitPath), match[1])) ===
        fs.realpathSync(gitDir)
    );
  } catch {
    return false;
  }
}

function gitRegistersWorktree(gitDir, checkoutDir) {
  const listed = spawnSync("git", [`--git-dir=${gitDir}`, "worktree", "list", "--porcelain"], {
    encoding: "utf8",
    maxBuffer: MAX_BUFFER,
  });
  if (!listed || listed.status !== 0) return false;
  let expected;
  try {
    expected = fs.realpathSync(checkoutDir);
  } catch {
    return false;
  }
  return listed.stdout
    .split(/\r?\n/)
    .filter((line) => line.startsWith("worktree "))
    .some((line) => {
      try {
        return fs.realpathSync(line.slice("worktree ".length)) === expected;
      } catch {
        return false;
      }
    });
}

// Resolve the working-tree directory the push targets, honoring cd / -C /
// --git-dir. A standalone --work-tree changes file presentation, not the Git
// repository whose refs are pushed, so repository discovery remains rooted at cwd/-C.
function resolveRepoDir(baseCwd, push) {
  let repoDir = baseCwd;
  if (push.cwdOverride) repoDir = path.resolve(repoDir, push.cwdOverride);
  if (push.dir) repoDir = path.resolve(repoDir, push.dir);
  if (push.gitDir) {
    const gd = path.resolve(repoDir, push.gitDir);
    if (path.basename(gd) === ".git") return path.dirname(gd);

    // Linked-worktree metadata records the checkout's .git file explicitly.
    // This is authoritative Git metadata, unlike a caller-controlled --work-tree.
    try {
      const checkoutGitFile = fs.readFileSync(path.join(gd, "gitdir"), "utf8").trim();
      const checkoutGitPath = path.resolve(gd, checkoutGitFile);
      const checkoutDir = path.dirname(checkoutGitPath);
      if (
        checkoutGitFile &&
        path.basename(checkoutGitPath) === ".git" &&
        checkoutPointsToGitDir(checkoutGitPath, gd) &&
        gitRegistersWorktree(gd, checkoutDir)
      )
        return checkoutDir;
    } catch {
      // Not a linked-worktree administrative directory.
    }

    // A separate Git directory records its checkout in core.worktree. Ask Git
    // to apply config path semantics rather than resolving relative paths here.
    const configured = spawnSync(
      "git",
      [`--git-dir=${gd}`, "config", "--path", "--get", "core.worktree"],
      { encoding: "utf8", maxBuffer: MAX_BUFFER }
    );
    if (configured && configured.status === 0 && configured.stdout.trim()) {
      const checkoutDir = path.resolve(gd, configured.stdout.trim());
      if (checkoutPointsToGitDir(path.join(checkoutDir, ".git"), gd)) return checkoutDir;
    }

    // A nonstandard Git directory with no authenticated checkout mapping could
    // be paired with any caller-controlled --work-tree. Do not guess.
    return null;
  }
  return repoDir;
}

function resolveExplicitGitDir(baseCwd, push) {
  if (!push.gitDir) return null;
  let dir = baseCwd;
  if (push.cwdOverride) dir = path.resolve(dir, push.cwdOverride);
  if (push.dir) dir = path.resolve(dir, push.dir);
  return path.resolve(dir, push.gitDir);
}

function gatePush(baseCwd, push) {
  if (push.cwdOverride === null || push.indeterminate) {
    emitDeny(
      "PM dev gate could not determine the repository for this push or its refspec after shell expansion. " +
        "Use literal repository and refspec values so the exact pushed commit and quality gates can be verified."
    );
    return true;
  }
  const repoDir = resolveRepoDir(baseCwd, push);
  if (!repoDir) {
    emitDeny(
      "PM dev gate could not bind this Git directory to an authoritative working tree. " +
        "Configure core.worktree (or use the linked-worktree metadata) before pushing."
    );
    return true;
  }
  const gitDir = resolveExplicitGitDir(baseCwd, push);

  // No canonical or legacy PM session store means this repository has nothing
  // for PM to protect. Resolve that before imposing PM's named-remote contract:
  // ordinary Git permits an implicit push directly to a URL or local path.
  try {
    if (!canonicalSessionsDirectory(repoDir)) return false;
    const preliminaryPush = parsePushArguments(push.args);
    if (preliminaryPush.refspecs.length === 0 && preliminaryPush.remote) {
      const configuredRemotes = gitCapture(repoDir, ["remote"], gitDir)
        .split(/\r?\n/)
        .filter(Boolean);
      if (!configuredRemotes.includes(preliminaryPush.remote)) {
        const inventory = loadCanonicalSessionIndex(repoDir);
        if (
          inventory.sessions.length === 0 &&
          inventory.candidates.size === 0 &&
          inventory.legacyMarkers.length === 0
        )
          return false;
      }
    }
  } catch (error) {
    emitDeny(`PM dev gate cannot inventory canonical sessions safely (${error.message}).`);
    return true;
  }

  const checkedOutBranch = currentBranch(repoDir, gitDir);
  const effective = effectivePushRefspecs(repoDir, push.args, checkedOutBranch, gitDir);
  if (effective.error) {
    emitDeny(
      `PM dev gate cannot resolve the exact implicit push updates (${effective.error}). ` +
        "Use one explicit source:destination refspec so every update can be verified."
    );
    return true;
  }
  const effectiveRefspecs = effective.refspecs;
  const shape = pushDestinationShape(push.args, checkedOutBranch, effectiveRefspecs);
  if (shape.error) {
    emitDeny(`PM dev gate cannot resolve the exact push destinations (${shape.error}).`);
    return true;
  }

  let selected;
  try {
    selected = selectCanonicalSessionTargets(repoDir, shape, checkedOutBranch);
  } catch (error) {
    emitDeny(`PM dev gate cannot inventory canonical sessions safely (${error.message}).`);
    return true;
  }
  if (selected.error) {
    emitDeny(
      `PM dev gate cannot bind push destinations to canonical sessions (${selected.error}).`
    );
    return true;
  }
  if (selected.targets.length === 0) return false;
  const [{ branch, slug, session }] = selected.targets;

  const sessionsDir = path.join(repoDir, ".pm", "dev-sessions");
  const canonicalSessionDir = path.join(sessionsDir, slug);
  const canonicalPath = path.join(canonicalSessionDir, "gates.json");
  const legacyPath = path.join(sessionsDir, `${slug}.gates.json`);
  const currentPath = path.join(sessionsDir, "current.gates.json");
  const manifestPath = canonicalPath;
  if (fs.existsSync(canonicalSessionDir) && !fs.existsSync(canonicalPath)) {
    blockUnverified(
      branch,
      `.pm/dev-sessions/${slug}/gates.json`,
      "canonical gate manifest is missing"
    );
    return true;
  }
  if (!fs.existsSync(manifestPath)) {
    if (fs.existsSync(legacyPath) || fs.existsSync(currentPath)) {
      blockUnverified(
        branch,
        `.pm/dev-sessions/${slug}/gates.json`,
        "legacy gate manifests are inspection-only; migrate and recertify the canonical session"
      );
      return true;
    }
    return false;
  }
  if (!fs.existsSync(path.join(canonicalSessionDir, "session.json"))) {
    blockUnverified(branch, manifestPath, "canonical sibling session.json is missing");
    return true;
  }
  if (
    session &&
    (session.authority?.push_feature_branch !== true ||
      !session.authority_log?.some(
        (entry) => Array.isArray(entry?.actions) && entry.actions.includes("push_feature_branch")
      ))
  ) {
    blockUnverified(
      branch,
      path.relative(repoDir, manifestPath).split(path.sep).join("/"),
      "canonical session does not grant push_feature_branch authority"
    );
    return true;
  }
  const manifestRel = path.relative(repoDir, manifestPath).split(path.sep).join("/");

  // VERIFICATION REGION. A push to the session branch is being gated against a
  // real manifest. Fail CLOSED on anything that stops a clean verdict — including
  // an unexpected throw in here: an error is not proof the gate passed.
  try {
    const pushed = sessionBranchPushSource(
      repoDir,
      push.args,
      branch,
      effectiveRefspecs,
      effective.source,
      gitDir,
      effective.expansionError
    );
    if (pushed.error) {
      blockUnverified(branch, manifestRel, pushed.error);
      return true;
    }
    const pushedSha = gitCapture(
      repoDir,
      ["rev-parse", "--verify", `${pushed.source}^{commit}`],
      gitDir
    );
    if (!/^[a-f0-9]{40,64}$/.test(pushedSha)) {
      blockUnverified(
        branch,
        manifestRel,
        `unable to resolve pushed source ${pushed.source} to one commit`
      );
      return true;
    }

    const checkerArgs = [
      "--manifest",
      manifestPath,
      "--commit",
      pushedSha,
      "--branch",
      branch,
      "--review-evidence-mode",
      "enforce",
      "--require-authority",
      "push_feature_branch",
    ];
    const destination = effective.remote
      ? { remote: effective.remote }
      : resolvePushRemote(repoDir, push.args, checkedOutBranch || branch, gitDir);
    if (destination.error) {
      blockUnverified(branch, manifestRel, destination.error);
      return true;
    }
    checkerArgs.push("--remote", destination.remote);

    const result = spawnSync(process.execPath, [CHECKER, ...checkerArgs], {
      cwd: repoDir,
      env: gitDir ? { ...process.env, GIT_DIR: gitDir, GIT_WORK_TREE: repoDir } : process.env,
      encoding: "utf8",
      maxBuffer: MAX_BUFFER,
    });

    // Couldn't spawn, killed by signal, or non-numeric exit → the gate could not
    // be evaluated, so it is not evidence the gate passed → BLOCK.
    if (!result || result.error || typeof result.status !== "number") {
      const detail =
        result && result.error ? result.error.code || result.error.message : "no verdict";
      blockUnverified(branch, manifestRel, detail);
      return true;
    }
    if (result.status === 0) return false;
    blockFailingGate(branch, manifestRel, `${result.stdout || ""}${result.stderr || ""}`);
    return true;
  } catch (err) {
    blockUnverified(branch, manifestRel, (err && err.message) || "hook error");
    return true;
  }
}

function main() {
  let raw = "";
  try {
    raw = fs.readFileSync(0, "utf8");
  } catch {
    return allow();
  }
  let payload;
  try {
    payload = JSON.parse(raw);
  } catch {
    return allow();
  }
  const command =
    payload && payload.tool_input && typeof payload.tool_input.command === "string"
      ? payload.tool_input.command
      : "";
  if (!command) return allow();
  const hasHeredoc = containsUnsupportedHeredoc(command);
  const executableCommand = hasHeredoc ? commandWithoutHeredocPayloads(command) : command;
  if (!executableCommand.includes("push")) return allow();
  if (hasHeredoc) {
    emitDeny(
      "PM dev gate cannot safely inspect a push command containing a shell here-document. " +
        "Run the push as a separate command so its repository, refspec, and quality gates can be verified."
    );
    return;
  }
  if (containsPushCommandSubstitution(command)) {
    emitDeny(
      "PM dev gate cannot safely inspect a git push inside shell command substitution. " +
        "Run the push as a separate command so its repository, refspec, and quality gates can be verified."
    );
    return;
  }
  const baseCwd =
    (payload && typeof payload.cwd === "string" && payload.cwd) ||
    process.env.CLAUDE_PROJECT_DIR ||
    process.cwd();
  const pushes = detectGitPushes(command, baseCwd);
  if (pushes.length === 0) return allow();
  for (const push of pushes) if (gatePush(baseCwd, push)) return;
  return allow();
}

try {
  main();
} catch {
  // Detection-phase safety net. A bug BEFORE we confirm a gated push must not
  // wedge Bash for innocent commands — fail OPEN here. (The verification region
  // above owns its own fail-CLOSED handling once a gated push is confirmed.)
  allow();
}
