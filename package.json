{
  "private": true,
  "name": "pm-plugin",
  "description": "Code quality tooling for the PM plugin",
  "scripts": {
    "lint": "eslint scripts/ tests/",
    "lint:fix": "eslint scripts/ tests/ --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "eval:check": "node scripts/evals/check.js",
    "eval:quality": "node scripts/evals/quality-cli.js",
    "eval:quality:scenarios": "node scripts/evals/generate-quality-scenarios.js",
    "eval:score": "node scripts/evals/score.js",
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test tests/*.test.js",
    "validate": "node scripts/validate.js --dir pm",
    "validate:plugin": "node scripts/validate.js --plugin",
    "skill:audit": "node scripts/skill-audit.js",
    "quality": "npm run lint && npm run format && npm run test && npm run eval:check",
    "bump": "node scripts/bump-version.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "c8": "^10.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0"
  }
}
