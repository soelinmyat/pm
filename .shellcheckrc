# Default shell dialect
shell=bash

# SC2086: Double quote to prevent globbing — too noisy for scripting style
# SC1091: Not following sourced file — can't resolve dynamic paths
# SC2034: Variable appears unused — false positives on loop counters and env vars
# SC2164: Use cd ... || exit — our scripts have set -e or intentional fallthrough
disable=SC2086,SC1091,SC2034,SC2164
