#!/usr/bin/env bash
# Pre-push checks:
# 1. Block direct pushes to main
# 2. Verify git tag exists for the current manifest version
# 3. Run test suite
# 4. Validate skill directory structure

remote="$1"
remote_url="$2"
push_ref_lines=()

resolve_authoritative_remote_head() {
  local remote_target="$remote_url"
  local output=""
  local head_ref=""
  local head_commit=""
  local head_branch=""

  if [[ -z "$remote_target" || "$remote_target" == "." ]]; then
    remote_target="$remote"
  fi
  if [[ -z "$remote_target" ]]; then
    return 1
  fi
  output=$(GIT_TERMINAL_PROMPT=0 GCM_INTERACTIVE=Never git ls-remote --symref "$remote_target" HEAD 2>/dev/null) || return 1
  head_ref=$(printf "%s\n" "$output" | sed -nE 's/^ref:[[:space:]]+(refs\/heads\/[^[:space:]]+)[[:space:]]+HEAD$/\1/p' | head -1)
  head_commit=$(printf "%s\n" "$output" | sed -nE 's/^([a-f0-9]{40,64})[[:space:]]+HEAD$/\1/p' | head -1)
  if [[ -z "$head_ref" || -z "$head_commit" ]]; then
    return 1
  fi
  if ! git cat-file -e "${head_commit}^{commit}" 2>/dev/null; then
    GIT_TERMINAL_PROMPT=0 GCM_INTERACTIVE=Never git fetch --no-tags --quiet "$remote_target" "$head_commit" 2>/dev/null || return 1
    git cat-file -e "${head_commit}^{commit}" 2>/dev/null || return 1
  fi
  head_branch="${head_ref#refs/heads/}"
  authoritative_base_commit="$head_commit"
  authoritative_base_ref="${remote}/${head_branch}"
  return 0
}

commit_contains_pm_runtime_inventory() {
  local commit="$1"
  git cat-file -e "$commit:plugin.config.json" 2>/dev/null ||
    git cat-file -e "$commit:.claude-plugin/plugin.json" 2>/dev/null ||
    git cat-file -e "$commit:.codex-plugin/plugin.json" 2>/dev/null ||
    {
      [[ -n "$(git ls-tree -r --name-only "$commit" -- commands 2>/dev/null)" ]] &&
        [[ -n "$(git ls-tree -r --name-only "$commit" -- skills 2>/dev/null)" ]]
    }
}

commit_or_history_contains_pm_runtime_inventory() {
  local commit="$1"
  local remote_commit="$2"
  local pathspec=""
  local changed_commit=""
  local candidate=""
  local history_paths=(
    "plugin.config.json"
    ".claude-plugin/plugin.json"
    ".codex-plugin/plugin.json"
    "commands"
    "skills"
  )

  if commit_contains_pm_runtime_inventory "$commit"; then
    return 0
  fi
  if [[ "$remote_commit" =~ ^[a-f0-9]{40,64}$ ]] &&
    git cat-file -e "${remote_commit}^{commit}" 2>/dev/null &&
    commit_contains_pm_runtime_inventory "$remote_commit"; then
    return 0
  fi
  for pathspec in "${history_paths[@]}"; do
    changed_commit=$(git rev-list --max-count=1 "$commit" -- "$pathspec" 2>/dev/null) || return 1
    if [[ -z "$changed_commit" ]]; then
      continue
    fi
    while IFS= read -r candidate; do
      if [[ -n "$candidate" ]] && commit_contains_pm_runtime_inventory "$candidate"; then
        return 0
      fi
    done < <(
      git rev-list --parents --max-count=1 "$changed_commit" 2>/dev/null |
        tr ' ' '\n'
    )
  done
  return 1
}

derive_gate_slug_from_worktree() {
  local worktree="$1"
  local branch="$2"
  local helper_path="$worktree/scripts/lib/session-slug.js"
  local error_file=""
  local output=""
  local detail=""

  gate_slug=""
  gate_slug_error=""
  if [[ ! -f "$helper_path" ]]; then
    gate_slug_error="pushed commit is missing canonical scripts/lib/session-slug.js"
    return 0
  fi
  error_file=$(mktemp "${TMPDIR:-/tmp}/pm-session-slug.XXXXXX") || {
    gate_slug_error="unable to allocate canonical session-slug validation output"
    return 0
  }
  if ! output=$(node - "$helper_path" "$branch" 2>"$error_file" <<'NODE'
const path = require("node:path");
const helperPath = path.resolve(process.argv[2]);
const branch = process.argv[3];
const helper = require(helperPath);
if (!helper || typeof helper.deriveSessionSlug !== "function") {
  throw new Error("canonical helper must export deriveSessionSlug");
}
const slug = helper.deriveSessionSlug(branch);
if (
  typeof slug !== "string" ||
  slug.length === 0 ||
  slug.length > 255 ||
  !/^[a-z0-9][a-z0-9._-]*$/.test(slug)
) {
  throw new Error("canonical helper returned an invalid session slug");
}
process.stdout.write(slug);
NODE
  ); then
    detail=$(head -c 300 "$error_file" | tr '\r\n' ' ')
    gate_slug_error="canonical session-slug helper failed${detail:+: $detail}"
    rm -f "$error_file"
    return 0
  fi
  rm -f "$error_file"
  gate_slug="$output"
}

verify_pm_commit_inventory() {
  local commit="$1"
  local required_path=""
  local missing=0
  local required_paths=""

  for required_path in "scripts/dev-gate-check.js" "plugin.config.json"; do
    if ! git cat-file -e "$commit:$required_path" 2>/dev/null; then
      echo "ERROR: pushed commit $commit is missing $required_path."
      missing=1
    fi
  done
  if [[ "$missing" -ne 0 ]]; then
    return 1
  fi

  required_paths=$(
    git show "$commit:plugin.config.json" 2>/dev/null | node -e '
      let input = "";
      process.stdin.setEncoding("utf8");
      process.stdin.on("data", chunk => { input += chunk; });
      process.stdin.on("end", () => {
        const config = JSON.parse(input);
        const commands = Array.isArray(config.commands) ? config.commands : [];
        for (const name of commands) {
          if (!/^[a-z0-9-]+$/.test(name)) {
            throw new Error(`invalid command name in plugin.config.json: ${name}`);
          }
          console.log(`commands/${name}.md`);
          console.log(`skills/${name}/SKILL.md`);
        }
      });
    '
  )
  if [[ "$?" -ne 0 ]]; then
    echo "ERROR: unable to read command inventory from $commit:plugin.config.json."
    return 1
  fi

  while IFS= read -r required_path; do
    if [[ -z "$required_path" ]]; then
      continue
    fi
    if ! git cat-file -e "$commit:$required_path" 2>/dev/null; then
      echo "ERROR: pushed commit $commit is missing $required_path from plugin.config.json."
      missing=1
    fi
  done <<<"$required_paths"

  return "$missing"
}

verify_release_preparation() {
  local commit="$1"
  local base_commit="$2"
  local slug="$3"
  local version=""
  local base_version=""
  local transaction=".pm/dev-sessions/${slug}/ship/release-transaction.json"
  local session=".pm/dev-sessions/${slug}/session.json"

  version=$(git show "$commit:plugin.config.json" 2>/dev/null | node -e '
    let input = "";
    process.stdin.setEncoding("utf8");
    process.stdin.on("data", chunk => { input += chunk; });
    process.stdin.on("end", () => process.stdout.write(JSON.parse(input).version || ""));
  ') || return 1
  base_version=$(git show "$base_commit:plugin.config.json" 2>/dev/null | node -e '
    let input = "";
    process.stdin.setEncoding("utf8");
    process.stdin.on("data", chunk => { input += chunk; });
    process.stdin.on("end", () => process.stdout.write(JSON.parse(input).version || ""));
  ') || return 1
  if [[ -z "$version" || "$version" == "$base_version" ]]; then
    return 0
  fi

  # One-release compatibility: the legacy bump command created a feature tag.
  # New releases use the prepared transaction and create the installable tag only on main.
  if git tag -l "v$version" | grep -qx "v$version"; then
    return 0
  fi
  if [[ ! -f "$transaction" || ! -f "$session" || -L "$transaction" || -L "$session" ]]; then
    echo "ERROR: release version $version requires canonical prepared-release evidence."
    echo "Expected $transaction and sibling session.json; feature-commit tags are not required."
    return 1
  fi
  if ! node - "$transaction" "$session" "$commit" "$version" <<'NODE'
const fs = require("node:fs");
const [transactionPath, sessionPath, commit, version] = process.argv.slice(2);
const transaction = JSON.parse(fs.readFileSync(transactionPath, "utf8"));
const session = JSON.parse(fs.readFileSync(sessionPath, "utf8"));
if (
  transaction.schema_version !== 1 ||
  transaction.run_id !== session.run_id ||
  transaction.slug !== session.slug ||
  transaction.owner?.role !== "root" ||
  transaction.release?.next_version !== version ||
  transaction.release?.tag !== `v${version}` ||
  transaction.release?.prepared_commit !== commit ||
  transaction.release?.tag_created !== false ||
  transaction.source?.head_branch !== session.source?.branch ||
  transaction.source?.base_branch !== session.source?.default_branch
) {
  throw new Error("prepared-release identity does not match pushed commit/session");
}
for (const kind of ["review", "qa", "verification"]) {
  if (transaction.evidence?.[kind]?.commit !== commit) {
    throw new Error(`prepared release lacks current ${kind} evidence`);
  }
}
NODE
  then
    echo "ERROR: prepared-release evidence is invalid or stale for $commit."
    return 1
  fi
}

run_commit_tests() {
  local commit="$1"
  local branch="$2"
  local test_tmp=""
  gate_slug=""
  gate_slug_error=""
  test_tmp=$(mktemp -d "${TMPDIR:-/tmp}/pm-pre-push-tests.XXXXXX") || exit 1
  rm -rf "$test_tmp"
  if ! git worktree add --detach --quiet "$test_tmp" "$commit"; then
    rm -rf "$test_tmp"
    echo "ERROR: unable to create test worktree for pushed commit $commit."
    return 1
  fi
  derive_gate_slug_from_worktree "$test_tmp" "$branch"
  if [[ -d "$test_tmp/tests" ]]; then
    echo "Running tests for $commit..."
    if ! (
      cd "$test_tmp" &&
        env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE -u GIT_PREFIX node --test tests/*.test.js
    ); then
      git worktree remove --force "$test_tmp" >/dev/null 2>&1 || rm -rf "$test_tmp"
      echo "ERROR: tests failed for pushed commit $commit."
      return 1
    fi
  fi
  git worktree remove --force "$test_tmp" >/dev/null 2>&1 || rm -rf "$test_tmp"
}

while read -r local_ref local_oid remote_ref remote_oid; do
  push_ref_lines+=("$local_ref $local_oid $remote_ref $remote_oid")
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    echo "ERROR: Direct push to main is not allowed."
    echo "Create a PR and merge instead."
    exit 1
  fi
done

# --- PM dev gate backstop ---
zero_oid="0000000000000000000000000000000000000000"
for push_ref_line in "${push_ref_lines[@]}"; do
  read -r local_ref local_oid remote_ref remote_oid <<<"$push_ref_line"
  if [[ "$local_oid" == "$zero_oid" || "$remote_ref" != refs/heads/* ]]; then
    continue
  fi

  branch_name="${remote_ref#refs/heads/}"
  if [[ -z "$branch_name" || "$branch_name" == "$remote_ref" ]]; then
    branch_name="${local_ref#refs/heads/}"
  fi
  if ! run_commit_tests "$local_oid" "$branch_name"; then
    exit 1
  fi

  pm_runtime_detected=0
  if commit_or_history_contains_pm_runtime_inventory "$local_oid" "$remote_oid"; then
    pm_runtime_detected=1
  fi

  authoritative_base_ref=""
  authoritative_base_commit=""
  if ! resolve_authoritative_remote_head; then
    if [[ "$pm_runtime_detected" -eq 1 ]]; then
      echo "ERROR: unable to resolve the authoritative remote HEAD for PM dev gate checks."
      echo "Verify the pre-push remote and network access, then retry."
      exit 1
    fi
    continue
  fi
  changed_pm_runtime_files=$(git diff --name-only "${authoritative_base_commit}...$local_oid" -- commands skills scripts hooks templates tests references agents plugin.config.json .claude-plugin .codex-plugin .codex/INSTALL.md README.md .githooks 2>/dev/null)
  if [[ "$?" -ne 0 ]]; then
    echo "ERROR: unable to diff authoritative remote HEAD ${authoritative_base_commit}...$local_oid for PM dev gate checks."
    exit 1
  fi
  if [[ -n "$gate_slug_error" && ( -n "$changed_pm_runtime_files" || "$pm_runtime_detected" -eq 1 ) ]]; then
    echo "ERROR: unable to derive the canonical PM dev session slug for pushed commit $local_oid."
    echo "${gate_slug_error}."
    echo "Restore a valid scripts/lib/session-slug.js in the pushed commit, then retry."
    exit 1
  fi
  if [[ -z "$gate_slug" ]]; then
    continue
  fi

  canonical_session_dir=".pm/dev-sessions/${gate_slug}"
  canonical_gate_manifest="${canonical_session_dir}/gates.json"
  gate_manifest="$canonical_gate_manifest"
  gate_session_detected=0
  if [[ -d "$canonical_session_dir" ]]; then
    gate_session_detected=1
  elif [[ -f ".pm/dev-sessions/${gate_slug}.gates.json" || -f ".pm/dev-sessions/current.gates.json" ]]; then
    echo "ERROR: Legacy PM gate manifests are inspection-only and cannot authorize delivery."
    echo "Migrate and recertify .pm/dev-sessions/${gate_slug}/gates.json with sibling session.json."
    exit 1
  fi
  if [[ -f "$canonical_gate_manifest" && ! -f "${canonical_session_dir}/session.json" ]]; then
    echo "ERROR: Canonical PM gate manifest requires sibling session.json."
    gate_session_detected=1
    exit 1
  fi

  if [[ -n "$changed_pm_runtime_files" || "$gate_session_detected" -eq 1 ]]; then
    if ! verify_pm_commit_inventory "$local_oid"; then
      exit 1
    fi
  fi
  if ! verify_release_preparation "$local_oid" "$authoritative_base_commit" "$gate_slug"; then
    exit 1
  fi

  if [[ -f "$gate_manifest" ]]; then
    checker_tmp=$(mktemp -d "${TMPDIR:-/tmp}/pm-dev-gate-check.XXXXXX") || exit 1
    checker_archive="$checker_tmp/scripts.tar"
    if ! git archive --format=tar --output="$checker_archive" "$local_oid" scripts plugin.config.json; then
      rm -rf "$checker_tmp"
      echo "ERROR: unable to archive scripts from pushed commit $local_oid."
      exit 1
    fi
    if ! tar -xf "$checker_archive" -C "$checker_tmp"; then
      rm -rf "$checker_tmp"
      echo "ERROR: unable to extract scripts from pushed commit $local_oid."
      exit 1
    fi
    rm -f "$checker_archive"
    echo "Checking PM dev gates for $branch_name..."
    if ! node "$checker_tmp/scripts/dev-gate-check.js" \
      --manifest "$gate_manifest" \
      --commit "$local_oid" \
      --branch "$branch_name" \
      --review-evidence-mode enforce \
      --require-authority push_feature_branch \
      --remote "$remote" \
      --base "$authoritative_base_ref"; then
      rm -rf "$checker_tmp"
      exit 1
    fi
    rm -rf "$checker_tmp"
  elif [[ -n "$changed_pm_runtime_files" || "$gate_session_detected" -eq 1 ]]; then
    echo "ERROR: PM dev gate manifest not found for branch $branch_name."
    echo "Expected $gate_manifest before pushing PM runtime/source changes."
    echo "Run all required dev gates, record .pm/dev-sessions/${gate_slug}/gates.json, then retry."
    exit 1
  fi
done

# --- Validate skill directory structure ---
# Every skill dir with a SKILL.md must have name/description frontmatter
# Dirs without SKILL.md are warned but not blocked (may be structural sub-dirs)
errors=0
for skill_dir in skills/*/; do
  skill_name=$(basename "$skill_dir")
  skill_file="$skill_dir/SKILL.md"
  if [[ ! -f "$skill_file" ]]; then
    echo "WARN: No SKILL.md in $skill_dir (skipping validation)"
    continue
  fi
  # Check for required frontmatter fields (name and description)
  if ! head -20 "$skill_file" | grep -q "^name:"; then
    echo "ERROR: $skill_file missing 'name:' in frontmatter"
    errors=$((errors + 1))
  fi
  if ! head -20 "$skill_file" | grep -q "^description:"; then
    echo "ERROR: $skill_file missing 'description:' in frontmatter"
    errors=$((errors + 1))
  fi
done

if [[ $errors -gt 0 ]]; then
  echo "ERROR: $errors skill validation error(s) found."
  exit 1
fi

exit 0
