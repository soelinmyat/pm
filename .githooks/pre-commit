#!/usr/bin/env bash
# Pre-commit checks:
# 1. Version consistency across all 4 manifests
# 2. JSON validity for manifest files
# 3. pm/ artifact validation (frontmatter schemas, ID collisions, broken refs)

set -euo pipefail

MANIFESTS=(
  ".claude-plugin/plugin.json"
  ".cursor-plugin/plugin.json"
  ".claude-plugin/marketplace.json"
  "gemini-extension.json"
)

# --- JSON validity ---
for f in "${MANIFESTS[@]}"; do
  if [[ -f "$f" ]]; then
    if ! python3 -m json.tool "$f" > /dev/null 2>&1; then
      echo "ERROR: Invalid JSON in $f"
      exit 1
    fi
  fi
done

# --- Version consistency ---
versions=()
for f in "${MANIFESTS[@]}"; do
  if [[ -f "$f" ]]; then
    v=$(python3 -c "import json; d=json.load(open('$f')); print(d.get('version') or d['plugins'][0]['version'])" 2>/dev/null)
    versions+=("$v:$f")
  fi
done

if [[ ${#versions[@]} -lt 2 ]]; then
  exit 0  # Not enough manifests to compare
fi

first_version="${versions[0]%%:*}"
for entry in "${versions[@]:1}"; do
  v="${entry%%:*}"
  f="${entry#*:}"
  if [[ "$v" != "$first_version" ]]; then
    echo "ERROR: Version mismatch across manifests."
    for e in "${versions[@]}"; do
      echo "  ${e#*:}: ${e%%:*}"
    done
    echo "All 4 manifests must have the same version."
    exit 1
  fi
done

# --- pm/ artifact validation ---
VALIDATE_SCRIPT="scripts/validate.js"
if [[ -d "pm" && -f "$VALIDATE_SCRIPT" ]]; then
  result=$(node "$VALIDATE_SCRIPT" --dir pm 2>/dev/null)
  ok=$(echo "$result" | python3 -c "import json,sys; print(json.load(sys.stdin).get('ok', False))" 2>/dev/null)
  if [[ "$ok" == "False" ]]; then
    echo "ERROR: pm/ artifact validation failed."
    echo "$result" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for d in data.get('details', []):
    if d['level'] == 'error':
        print(f\"  {d['file']}: {d['message']}\")
" 2>/dev/null
    exit 1
  fi
fi

exit 0
